@page "/pods"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@using GameScoreboard.Models
@using GameScoreboard.Services
@using GameScoreboard.Services.Tracking
@inject IDataService DataService
@inject AppState AppState

<div class="min-h-screen px-4 py-8" style="color: var(--er-text);">
    <div class="mx-auto max-w-7xl space-y-8">
        <section class="elden-dashboard-section elden-dashboard-hero elden-lively-panel">
            <div class="relative z-10">
                <div class="text-center mb-6">
                    <div class="elden-dashboard-eyebrow">Council Navigation</div>
                    <h1 class="title-glow text-4xl mb-2">War Council</h1>
                    <p class="font-body text-lg max-w-3xl mx-auto" style="color: var(--er-text-dim);">The strongest teams rise here first. Enter the council, read the top three, then descend into the roster floor below for a specific pod.</p>
                    <div class="elden-divider-ornate mx-auto mt-4" style="max-width: 300px;"></div>
                </div>

                @if (_isLoading)
                {
                    <div class="flex flex-col items-center justify-center mt-10">
                        <div class="elden-loading-rune mb-6"></div>
                        <p class="font-heading text-sm" style="color: var(--er-gold-dim); letter-spacing: 0.1em; animation: gold-pulse 2s ease infinite;">
                            @_loadingStatus
                        </p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="flex flex-col items-center justify-center mt-10">
                        <p class="font-body text-lg mb-4" style="color: var(--er-red-bright);">@_errorMessage</p>
                        <button @onclick="RetryLoad" class="elden-btn elden-btn-primary">Retry</button>
                    </div>
                }
                else if (!_pods.Any())
                {
                    <div class="flex flex-col items-center justify-center mt-10">
                        <p class="font-body text-lg" style="color: var(--er-text-dim);">No teams with performance data found.</p>
                        <p class="font-body text-sm mt-2" style="color: var(--er-text-muted);">Use the Team Tracker to enter metrics first.</p>
                    </div>
                }
                else
                {
                    <div class="council-top-three-grid">
                        @foreach (var pod in _podLeaderboard.Take(3))
                        {
                            string rankClass = pod.Rank == 1 ? "rank-1" : pod.Rank == 2 ? "rank-2" : "rank-3";
                            string rankColor = pod.Rank == 1 ? "elden-rank-gold" : pod.Rank == 2 ? "elden-rank-silver" : "elden-rank-bronze";

                            <button @onclick="() => NavigateToPod(pod.Name)"
                                    @onmouseover="PlayHover"
                                    class="elden-rank-card council-rank-card @rankClass">
                                <div class="font-heading text-xs uppercase tracking-[0.28em] mb-2" style="color: var(--er-text-dim);">Rank #@pod.Rank</div>
                                <div class="font-heading text-xl mb-2 @rankColor">@pod.Name</div>
                                <div class="font-mono text-3xl mb-1" style="color: var(--er-gold-bright);">@pod.Score.ToString("F1")</div>
                                <div class="font-body text-xs" style="color: var(--er-text-dim);">average weighted score</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </section>

        @if (!_isLoading && string.IsNullOrEmpty(_errorMessage) && _pods.Any())
        {
            <section class="elden-dashboard-section">
                <div class="elden-dashboard-section-header">
                    <div>
                        <div class="elden-dashboard-eyebrow">Council Floor</div>
                        <h2 class="elden-dashboard-section-title">Choose A Team</h2>
                        <p class="elden-dashboard-section-copy">The full pod roster stays accessible here, but the council opens with the top-ranked teams first.</p>
                    </div>
                    <div class="font-body text-sm" style="color: var(--er-text-dim);">@_pods.Count teams with live performance data</div>
                </div>

                <div class="pod-index-grid">
                    @foreach (var pod in _pods)
                    {
                        var leaderboardEntry = _podLeaderboard.FirstOrDefault(entry => entry.Name.Equals(pod, StringComparison.OrdinalIgnoreCase));

                        <button @onclick="() => NavigateToPod(pod)"
                                @onmouseover="PlayHover"
                                class="elden-card elden-card-ornate p-6 cursor-pointer text-left group">
                            <div class="elden-corners-inner h-full">
                                <div class="flex items-start justify-between gap-4 mb-4">
                                    <span class="font-heading text-xs tracking-widest uppercase" style="color: var(--er-gold-dim);">Team</span>
                                    @if (leaderboardEntry != null)
                                    {
                                        <span class="font-mono text-xs px-2 py-1 rounded-full" style="background: rgba(200, 169, 78, 0.08); color: var(--er-gold-dim);">#@leaderboardEntry.Rank</span>
                                    }
                                </div>
                                <h2 class="font-heading text-xl mb-3 transition-colors duration-300 group-hover:text-gold-bright" style="color: var(--er-gold);">
                                    @pod
                                </h2>
                                <div class="elden-divider mb-3" style="max-width: 120px;"></div>
                                <div class="flex items-center justify-between gap-4">
                                    <p class="font-mono text-sm" style="color: var(--er-text-dim);">@GetPodMemberCount(pod) champions</p>
                                    @if (leaderboardEntry != null)
                                    {
                                        <p class="font-mono text-sm" style="color: var(--er-gold-bright);">@leaderboardEntry.Score.ToString("F1")</p>
                                    }
                                </div>
                            </div>
                        </button>
                    }
                </div>

                <!-- Hidden Pod Tracker Card -->
                <div id="team-tracker-card" @onclick='() => NavigateTo("/podtracker")'
                     @onmouseover="PlayHover"
                     class="hidden mt-8 elden-card p-6 cursor-pointer text-center" style="border-color: var(--er-purple);">
                    <h2 class="font-heading text-xl mb-1" style="color: var(--er-purple);">Team Tracker</h2>
                    <p class="font-body text-sm" style="color: var(--er-text-dim);">Input and update team metrics</p>
                </div>
            </section>
        }
    </div>
</div>

@code {
    private List<string> _pods = new();
    private List<TeamMember>? _allMembers;
    private List<RankedMember> _podLeaderboard = new();
    private string? _latestPeriod;
    private bool _isLoading = true;
    private string _loadingStatus = "Connecting to server...";
    private string? _errorMessage;

    private static bool IsPodDepartment(string dept) => PodMetricCatalog.IsPodDepartment(dept);

    protected override async Task OnInitializedAsync()
    {
        await LoadPodsAsync();
    }

    private async Task LoadPodsAsync()
    {
        _isLoading = true;
        _loadingStatus = "Fetching team data...";
        _errorMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine("[PodIndex] Fetching all team members (using cache)...");
            _allMembers = await AppState.GetOrFetchMembersAsync(DataService);
            Console.WriteLine($"[PodIndex] Received {_allMembers?.Count ?? 0} members total");

            var membersWithMetrics = (_allMembers ?? new())
                .Where(m => IsPodDepartment(m.Department) && m.MetricRecords?.Any() == true)
                .ToList();

            _pods = membersWithMetrics
                .GroupBy(m => m.Department, StringComparer.OrdinalIgnoreCase)
                .Where(g => g.Any(member => member.MetricRecords?.Any() == true))
                .Select(g => g.Key)
                .OrderBy(d => d)
                .ToList();

            _latestPeriod = PodLeaderboardCalculator.DetermineLatestPeriod(membersWithMetrics);
            _podLeaderboard = PodLeaderboardCalculator.CalculatePodLeaderboard(membersWithMetrics, _latestPeriod);

            Console.WriteLine($"[PodIndex] Found {_pods.Count} teams with data: [{string.Join(", ", _pods)}]");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PodIndex] LoadPodsAsync FAILED: {ex.Message}");
            _errorMessage = $"Failed to load pod data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RetryLoad() => await LoadPodsAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initKeySequenceDetector");
        }
    }

    private int GetPodMemberCount(string pod) =>
        _allMembers?.Count(m =>
            m.Department.Equals(pod, StringComparison.OrdinalIgnoreCase) &&
            m.MetricRecords?.Any() == true) ?? 0;

    private async Task NavigateToPod(string podName)
    {
        try { await JSRuntime.InvokeVoidAsync("eldenAudio.playClick"); } catch { }
        NavigationManager.NavigateTo($"/pods/{podName}");
    }

    private async Task NavigateTo(string path)
    {
        try { await JSRuntime.InvokeVoidAsync("eldenAudio.playClick"); } catch { }
        NavigationManager.NavigateTo(path);
    }

    private async Task PlayHover()
    {
        try { await JSRuntime.InvokeVoidAsync("eldenAudio.playHover"); } catch { }
    }
}
