    private void LoadMembersForSelectedPod()
    {
        _currentPodMembers = null;
        _inputValues.Clear();
        _saveError = null;
        _saveSuccessMessage = null;

        if (string.IsNullOrEmpty(_selectedPod)) return;

        _currentPodMembers = _allPodMembers?
            .Where(m => m.Department.Equals(_selectedPod, StringComparison.OrdinalIgnoreCase))
            .ToList();

        InitializeInputValues();

        // If we have parsed data for this pod, overlay it
        if (_parsedPodData.TryGetValue(_selectedPod, out var podData))
        {
            foreach (var (memberId, values) in podData)
            {
                if (_inputValues.ContainsKey(memberId))
                {
                    foreach (var (key, val) in values)
                        _inputValues[memberId][key] = val;
                }
            }
        }
        CalculateFocusFive();
        StateHasChanged();
    }

    private void InitializeInputValues()
    {
        _inputValues.Clear();
        if (_currentPodMembers == null) return;
        foreach (var member in _currentPodMembers)
        {
            var memberInputs = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var key in _podMetricKeys) memberInputs[key] = string.Empty;
            _inputValues[member.Id] = memberInputs;
        }
    }

    // ══════════════════════════════════════════════════════════
    //  PASTE PARSER - handles entire Excel pod tracker sheets
    // ══════════════════════════════════════════════════════════

    // OLD FORMAT PARSER - Kept as backup for reference
    private async Task HandlePastedData_OLD_FORMAT()
    {
        _parseResults = null;
        _parseLog.Clear();
        _parsedPodData.Clear();
        _uploadStatusMessage = null;
        _uploadSuccess = false;
        _isParsing = true;
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(_pastedData))
        {
            _uploadStatusMessage = "Paste area is empty.";
            _isParsing = false;
            return;
        }

        try
        {
            var lines = _pastedData.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
            if (lines.Length < 3)
            {
                _uploadStatusMessage = "Need more data - paste the full team tracker sheet.";
                _isParsing = false;
                return;
            }

            // Step 1: Detect column layout from header row
            int nameCol = 0, rphCol = 4, appEffCol = 7, pmEffCol = 10, fiveStarCol = 13, warCol = 15, accCol = 17;
            int headerRowIdx = FindHeaderRow(lines, ref nameCol, ref rphCol, ref appEffCol, ref pmEffCol, ref fiveStarCol, ref warCol, ref accCol);

            if (headerRowIdx >= 0)
                _parseLog.Add($"✓ Header found at row {headerRowIdx + 1}. Columns: Name={nameCol}, RPH={rphCol}, AppEff={appEffCol}, PMEff={pmEffCol}, 5Star={fiveStarCol}, Warranty={warCol}, Acc={accCol}");
            else
                _parseLog.Add("⚠ No header row detected. Using default column layout (Employee at col 0).");

            // Step 2: Walk through lines detecting pods and member data
            var results = new List<PodParseInfo>();
            PodParseInfo? currentPod = null;
            int startRow = headerRowIdx >= 0 ? headerRowIdx + 1 : 0;
            var membersNeedingGoalUpdate = new Dictionary<int, TeamMember>();
            var nameCache = new Dictionary<string, TeamMember>(StringComparer.OrdinalIgnoreCase);

            for (int i = startRow; i < lines.Length; i++)
            {
                var cells = lines[i].Split('\t');

                // Skip lines with very few cells
                if (cells.Length < 2) continue;
                if (cells.All(c => string.IsNullOrWhiteSpace(c))) continue;

                int rowNum = i + 1;

                // Detect pod section header
                var detectedPodName = DetectPodHeader(cells, nameCol);
                if (detectedPodName != null)
                {
                    _parseLog.Add($"Row {rowNum}: skipped (pod header)");
                    string systemName = ResolvePodName(detectedPodName);
                    bool isNew = !PodExistsInSystem(systemName);

                    currentPod = new PodParseInfo { ExcelName = detectedPodName, SystemName = systemName, IsNew = isNew };
                    results.Add(currentPod);

                    if (detectedPodName != systemName)
                        _parseLog.Add($"✓ Pod '{detectedPodName}' → mapped to '{systemName}'");
                    else if (!isNew)
                        _parseLog.Add($"✓ Pod '{detectedPodName}' found in system");
                    else
                        _parseLog.Add($"★ Pod '{detectedPodName}' is new - will be created on save");

                    continue;
                }

                // Skip rows before first pod header is detected
                if (currentPod == null)
                {
                    _parseLog.Add($"Row {rowNum}: skipped (no pod yet)");
                    continue;
                }

                var activePod = currentPod;

                // Skip #N/A rows
                if (IsNARow(cells))
                {
                    _parseLog.Add($"Row {rowNum}: skipped (#N/A)");
                    continue;
                }

                // Extract member name
                if (cells.Length <= nameCol)
                {
                    _parseLog.Add($"Row {rowNum}: skipped (no name)");
                    continue;
                }
                string memberName = (cells[nameCol] ?? "").Trim();
                if (string.IsNullOrEmpty(memberName))
                {
                    _parseLog.Add($"Row {rowNum}: skipped (no name)");
                    continue;
                }

                // If this row just repeats the current pod label (e.g. Luis-Front End),
                // treat it as a pod header/label row, not a team member.
                if (currentPod != null &&
                    (memberName.Equals(currentPod.ExcelName, StringComparison.OrdinalIgnoreCase) ||
                     memberName.Equals(currentPod.SystemName, StringComparison.OrdinalIgnoreCase)))
                {
                    _parseLog.Add($"Row {rowNum}: skipped (pod label row)");
                    continue;
                }

                // Skip if it looks like a sub-header or metadata row
                if (_skipKeywords.Contains(memberName))
                {
                    _parseLog.Add($"Row {rowNum}: skipped (header/metadata)");
                    continue;
                }

                // Validate it's a real data row (needs numeric data)
                int numericCells = CountNumericCells(cells, nameCol + 1);
                if (numericCells < 2)
                {
                    _parseLog.Add($"Row {rowNum}: skipped (fewer than 2 numeric cells) - '{memberName}'");
                    continue;
                }

                // Match member to existing system entries
                var podMembers = _allPodMembers?
                    .Where(m => m.Department.Equals(activePod.SystemName, StringComparison.OrdinalIgnoreCase))
                    .ToList() ?? new();

                // Normalize name to reduce duplicate creation inside a single parse run
                string normalizedName = NormalizeMemberName(memberName);
                TeamMember? matched = null;

                if (nameCache.TryGetValue(normalizedName, out var cached))
                {
                    matched = cached;
                    if (!matched.Department.Equals(activePod.SystemName, StringComparison.OrdinalIgnoreCase))
                    {
                        string prevPod = matched.Department;
                        matched.Department = activePod.SystemName;
                        _parseLog.Add($"Moved '{memberName}' to '{activePod.SystemName}' (previously in '{prevPod}')");
                    }
                }
                else
                {
                    matched = MatchMember(memberName, podMembers);
                }

                if (matched == null)
                {
                    // Try all pod members (maybe they moved)
                    var allMatch = MatchMember(memberName, _allPodMembers ?? new());
                    if (allMatch != null)
                    {
                        string prevPod = allMatch.Department;
                        allMatch.Department = activePod.SystemName;
                        matched = allMatch;
                        _parseLog.Add($"Moved '{memberName}' to '{activePod.SystemName}' (previously in '{prevPod}')");
                    }
                }

                if (matched == null)
                {
                    // Create new member
                    var newMember = new TeamMember
                    {
                        Name = memberName,
                        Department = activePod.SystemName,
                        AvatarUrl = "images/avatars/avatar4.png"
                    };

                    try
                    {
                        await DataService.AddTeamMemberAsync(newMember);
                        _allPodMembers ??= new List<TeamMember>();
                        _allPodMembers.Add(newMember);
                        matched = newMember;
                        activePod.NewMembers.Add(memberName);
                        _parseLog.Add($"★ Created '{memberName}' in '{activePod.SystemName}'");
                    }
                    catch (Exception ex)
                    {
                        activePod.UnmatchedNames.Add(memberName);
                        _parseLog.Add($"Row {rowNum}: ✗ Failed to create '{memberName}': {ex.Message}");
                        continue;
                    }
                }
                else
                {
                    activePod.MatchedMembers.Add(memberName);
                }

                // Cache the resolved member so repeated rows in the same paste
                // don't create duplicates or re-run matching logic.
                if (matched != null)
                {
                    nameCache[normalizedName] = matched;
                }

                // Extract KPI values from known column positions
                var values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                {
                    ["RPH"] = CleanCurrency(SafeGet(cells, rphCol)),
                    ["AppEff"] = CleanCurrency(SafeGet(cells, appEffCol)),
                    ["PMEff"] = CleanCurrency(SafeGet(cells, pmEffCol)),
                    ["Surveys"] = SafeGet(cells, fiveStarCol).Trim(),
                    ["WarrantyAttach"] = CleanPercentage(SafeGet(cells, warCol)),
                    ["AccAttach"] = CleanPercentage(SafeGet(cells, accCol))
                };

                _parseLog.Add($"Row {rowNum}: Name={memberName} | RPH={values["RPH"]} | AppEff={values["AppEff"]} | PMEff={values["PMEff"]} | Warranty={values["WarrantyAttach"]}% | Acc={values["AccAttach"]}%");

                // Extract per-person target goals from the right-hand side of the sheet
                if (cells.Length >= 6 && matched != null)
                {
                    int targetStart = cells.Length - 6;
                    string rphGoalRaw = CleanCurrency(SafeGet(cells, targetStart));           // Revenue column (RPH goal)
                    string appEffGoalRaw = CleanCurrency(SafeGet(cells, targetStart + 2));    // App Eff target
                    string pmEffGoalRaw = CleanCurrency(SafeGet(cells, targetStart + 3));     // PM Eff target
                    string warrantyGoalRaw = CleanPercentage(SafeGet(cells, targetStart + 4)); // Warranty %
                    string accGoalRaw = CleanPercentage(SafeGet(cells, targetStart + 5));      // Acc Attach %

                    bool anyGoalSet = false;

                    double? rphGoal = ParseNullableDouble(rphGoalRaw);
                    if (rphGoal.HasValue)
                    {
                        matched.RphGoal = rphGoal.Value;
                        anyGoalSet = true;
                    }

                    double? appEffGoal = ParseNullableDouble(appEffGoalRaw);
                    if (appEffGoal.HasValue)
                    {
                        matched.AppEffGoal = appEffGoal.Value;
                        anyGoalSet = true;
                    }

                    double? pmEffGoal = ParseNullableDouble(pmEffGoalRaw);
                    if (pmEffGoal.HasValue)
                    {
                        matched.PmEffGoal = pmEffGoal.Value;
                        anyGoalSet = true;
                    }

                    double? warrantyGoal = ParseNullableDouble(warrantyGoalRaw);
                    if (warrantyGoal.HasValue)
                    {
                        matched.WarrantyAttachGoal = warrantyGoal.Value;
                        anyGoalSet = true;
                    }

                    double? accGoal = ParseNullableDouble(accGoalRaw);
                    if (accGoal.HasValue)
                    {
                        matched.AccAttachGoal = accGoal.Value;
                        anyGoalSet = true;
                    }

                    if (anyGoalSet && !membersNeedingGoalUpdate.ContainsKey(matched.Id))
                    {
                        membersNeedingGoalUpdate[matched.Id] = matched;
                    }
                }

                // Store parsed values
                if (matched == null)
                    continue;

                if (!_parsedPodData.ContainsKey(activePod.SystemName))
                    _parsedPodData[activePod.SystemName] = new();
                _parsedPodData[activePod.SystemName][matched.Id] = values;
            }

            // Persist any updated per-person targets
            if (membersNeedingGoalUpdate.Any())
            {
                foreach (var member in membersNeedingGoalUpdate.Values)
                {
                    await DataService.UpdateTeamMemberAsync(member);
                }
            }

            _parseResults = results;

            // Update pod dropdown to include new pods
            foreach (var pod in results)
            {
                if (!_pods.Contains(pod.SystemName, StringComparer.OrdinalIgnoreCase))
                    _pods.Add(pod.SystemName);
            }
            _pods.Sort(StringComparer.OrdinalIgnoreCase);

            // Build summary
            int totalMatched = results.Sum(r => r.MatchedMembers.Count);
            int totalNew = results.Sum(r => r.NewMembers.Count);
            int totalUnmatched = results.Sum(r => r.UnmatchedNames.Count);

            _uploadSuccess = (totalMatched + totalNew) > 0;
            _uploadStatusMessage = $"Parsed {totalMatched + totalNew} members across {results.Count} teams.";
            if (totalNew > 0) _uploadStatusMessage += $" ({totalNew} new members created)";
            if (totalUnmatched > 0) _uploadStatusMessage += $" ({totalUnmatched} could not be matched)";

            _pastedData = string.Empty;

            // Auto-select first pod with data
            if (results.Any())
            {
                _selectedPod = results.First().SystemName;
                LoadMembersForSelectedPod();
            }
        }
        catch (Exception ex)
        {
            _uploadStatusMessage = $"Parse error: {ex.Message}";
            _uploadSuccess = false;
            _parseLog.Add($"✗ Fatal: {ex.Message}");
            Console.WriteLine($"PodTracker parse error: {ex}");
        }
        finally
        {
            _isParsing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ══════════════════════════════════════════════════════════
    //  NEW FORMAT PARSER - handles Employee Relative Performance Dashboard format
    // ══════════════════════════════════════════════════════════

    private async Task HandlePastedData()
    {
        _parseResults = null;
        _parseLog.Clear();
        _parsedPodData.Clear();
        _uploadStatusMessage = null;
        _uploadSuccess = false;
        _isParsing = true;
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(_pastedData))
        {
            _uploadStatusMessage = "Paste area is empty.";
            _isParsing = false;
            return;
        }

        try
        {
            var lines = _pastedData.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
            if (lines.Length < 3)
            {
                _uploadStatusMessage = "Need more data - paste the full team tracker sheet.";
                _isParsing = false;
                return;
            }

            // Detect format: New format has "Employee Relative Performance Dashboard Output" in header
            bool isNewFormat = lines.Any(l => l.Contains("Employee Relative Performance Dashboard Output", StringComparison.OrdinalIgnoreCase));

            if (isNewFormat)
            {
                await HandlePastedData_NewFormat(lines);
            }
            else
            {
                await HandlePastedData_OLD_FORMAT();
            }
        }
        catch (Exception ex)
        {
            _uploadStatusMessage = $"Parse error: {ex.Message}";
            _uploadSuccess = false;
            _parseLog.Add($"✗ Fatal: {ex.Message}");
            Console.WriteLine($"PodTracker parse error: {ex}");
        }
        finally
        {
            _isParsing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ══════════════════════════════════════════════════════════
    //  NEW FORMAT PARSER - Employee Relative Performance Dashboard
    // ══════════════════════════════════════════════════════════
    private async Task HandlePastedData_NewFormat(string[] lines)
    {
        var parseResult = _importParser.Parse(string.Join(Environment.NewLine, lines), _allPodMembers ?? new List<TeamMember>());
        _parseLog = parseResult.Logs.Select(log => log.ToDisplayString()).ToList();

        if (!parseResult.HasRows)
        {
            _uploadSuccess = false;
            _uploadStatusMessage = parseResult.StatusMessage;
            return;
        }

        var results = new List<PodParseInfo>();
        foreach (var parsedPod in parseResult.Pods)
        {
            var podInfo = new PodParseInfo
            {
                ExcelName = parsedPod.ExcelName,
                SystemName = parsedPod.SystemName,
                IsNew = parsedPod.IsNew
            };

            foreach (var row in parsedPod.Rows)
            {
                TeamMember? member = row.Match.Member;
                if (row.Match.Kind == PodMemberMatchKind.NewMember)
                {
                    var newMember = new TeamMember
                    {
                        Name = row.MemberName,
                        Department = parsedPod.SystemName,
                        AvatarUrl = "images/avatars/avatar4.png"
                    };

                    try
                    {
                        await DataService.AddTeamMemberAsync(newMember);
                        _allPodMembers ??= new List<TeamMember>();
                        _allPodMembers.Add(newMember);
                        member = newMember;
                        _parseLog.Add($"★ Created '{row.MemberName}' in '{parsedPod.SystemName}'.");
                    }
                    catch (Exception ex)
                    {
                        podInfo.UnmatchedNames.Add(row.MemberName);
                        _parseLog.Add($"✗ Row {row.RowNumber}: failed to create '{row.MemberName}': {ex.Message}");
                        continue;
                    }
                }

                if (member == null)
                {
                    podInfo.UnmatchedNames.Add(row.MemberName);
                    continue;
                }

                if (!member.Department.Equals(parsedPod.SystemName, StringComparison.OrdinalIgnoreCase))
                {
                    _membersPendingDepartmentUpdate.Add(member.Id);
                    member.Department = parsedPod.SystemName;
                }

                if (!_parsedPodData.TryGetValue(parsedPod.SystemName, out var podData))
                {
                    podData = new Dictionary<int, Dictionary<string, string>>();
                    _parsedPodData[parsedPod.SystemName] = podData;
                }

                podData[member.Id] = new Dictionary<string, string>(row.MetricValues, StringComparer.OrdinalIgnoreCase);

                if (row.Match.Kind == PodMemberMatchKind.NewMember)
                {
                    podInfo.NewMembers.Add(row.MemberName);
                }
                else
                {
                    podInfo.MatchedMembers.Add(row.MemberName);
                }
            }

            foreach (var unmatchedName in parsedPod.UnmatchedNames)
            {
                if (!podInfo.UnmatchedNames.Contains(unmatchedName, StringComparer.OrdinalIgnoreCase))
                {
                    podInfo.UnmatchedNames.Add(unmatchedName);
                }
            }

            results.Add(podInfo);

            if (!_pods.Contains(parsedPod.SystemName, StringComparer.OrdinalIgnoreCase))
            {
                _pods.Add(parsedPod.SystemName);
            }
        }

        _pods.Sort(StringComparer.OrdinalIgnoreCase);
        _parseResults = results;
        _uploadSuccess = results.Any(p => p.MatchedMembers.Any() || p.NewMembers.Any());
        _uploadStatusMessage = parseResult.StatusMessage;

        var totalUnmatched = results.Sum(r => r.UnmatchedNames.Count);
        if (totalUnmatched > 0)
        {
            _uploadStatusMessage += $" ({totalUnmatched} could not be matched)";
        }

        _pastedData = string.Empty;

        if (results.Any())
        {
            _selectedPod = results.First().SystemName;
            LoadMembersForSelectedPod();
        }
    }

    // Detect pod header in new format: names ending with -PC/CA, -HT/CA, -PC/APPL, etc.
    private bool IsNewFormatPodHeader(string nameCell)
    {
        if (string.IsNullOrEmpty(nameCell)) return false;
        if (nameCell.Length < 5) return false;

        // Check against pod aliases (includes leader names mapping to pods)
        if (_podAliases.ContainsKey(nameCell)) return true;

        // Also check if just the leader name matches (e.g., "Drew Carillo" -> pod)
        foreach (var alias in _podAliases.Keys)
        {
            if (nameCell.Equals(alias, StringComparison.OrdinalIgnoreCase))
                return true;
        }

        // New format pod headers end with department codes
        string[] deptCodes = { "PC/CA", "HT/CA", "PC/APPL", "HT/APPL", "DI/HT", "Center Store" };
        foreach (var code in deptCodes)
        {
            if (nameCell.EndsWith(code, StringComparison.OrdinalIgnoreCase))
                return true;
        }

        // Check if it looks like a leader name with department code
        // e.g., "Matt Nelsen-PC/CA", "Christian Nazario-HT/CA"
        if (nameCell.Contains("-") && nameCell.Length > 6)
        {
            var parts = nameCell.Split('-');
            if (parts.Length == 2)
            {
                string leaderName = parts[0].Trim();
                string deptCode = parts[1].Trim();
                // Leader name should have at least first and last name
                // AND deptCode must be a valid department code (not just any word)
                if (leaderName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length >= 2)
                {
                    string[] validCodes = { "PC/CA", "HT/CA", "PC/APPL", "HT/APPL", "DI/HT", "Center Store" };
                    if (validCodes.Any(c => deptCode.Equals(c, StringComparison.OrdinalIgnoreCase)))
                        return true;
                }
            }
        }

        return false;
    }

    // ── Header detection ──
    private int FindHeaderRow(string[] lines, ref int nameCol, ref int rphCol, ref int appEffCol, ref int pmEffCol, ref int fiveStarCol, ref int warCol, ref int accCol)
    {
        for (int i = 0; i < Math.Min(lines.Length, 15); i++)
        {
            var cells = lines[i].Split('\t');
            int employeeIdx = Array.FindIndex(cells, c => c.Trim().Equals("Employee", StringComparison.OrdinalIgnoreCase));
            if (employeeIdx < 0) continue;

            nameCol = employeeIdx;

            bool rphSet = false, appEffSet = false, pmEffSet = false, fiveStarSet = false, warSet = false, accSet = false;
            for (int k = employeeIdx + 1; k < cells.Length; k++)
            {
                string h = cells[k].Trim();
                if (string.IsNullOrEmpty(h)) continue;

                if (!rphSet && h.Contains("RPH", StringComparison.OrdinalIgnoreCase))
                    { rphCol = k; rphSet = true; }
                else if (!appEffSet && ((h.Contains("App", StringComparison.OrdinalIgnoreCase) && h.Contains("Eff", StringComparison.OrdinalIgnoreCase))
                         || h.StartsWith("Apps", StringComparison.OrdinalIgnoreCase)))
                    { appEffCol = k + 1; appEffSet = true; }
                else if (!pmEffSet && ((h.Contains("PM", StringComparison.OrdinalIgnoreCase) && h.Contains("Eff", StringComparison.OrdinalIgnoreCase))
                         || h.StartsWith("PMs", StringComparison.OrdinalIgnoreCase)))
                    { pmEffCol = k + 1; pmEffSet = true; }
                else if (!fiveStarSet && (h.Contains("Surveys", StringComparison.OrdinalIgnoreCase) || h.Contains("5 Star", StringComparison.OrdinalIgnoreCase)
                         || h.Contains("5-Star", StringComparison.OrdinalIgnoreCase)))
                    { fiveStarCol = k + 1; fiveStarSet = true; }
                else if (!warSet && h.Contains("Warranty", StringComparison.OrdinalIgnoreCase))
                    { warCol = k; warSet = true; }
                else if (!accSet && h.Contains("Accessory", StringComparison.OrdinalIgnoreCase))
                    { accCol = k; accSet = true; }
            }
            return i;
        }
        return -1;
    }

    // ── Pod section header detection ──
    private string? DetectPodHeader(string[] cells, int nameCol)
    {
        // Prefer using the "name" column to detect pod headers, even if
        // there are numeric target values in other columns (e.g. Luis-Front End).
        if (nameCol >= 0 && nameCol < cells.Length)
        {
            var nameCell = (cells[nameCol] ?? string.Empty).Trim();
            if (!string.IsNullOrEmpty(nameCell) &&
                nameCell.Length >= 4 &&
                !_skipKeywords.Contains(nameCell) &&
                !nameCell.StartsWith("$") &&
                !nameCell.StartsWith("#") &&
                !nameCell.EndsWith("%") &&
                // Skip pure numbers (e.g., "1411")
                !double.TryParse(nameCell.Replace(",", string.Empty), NumberStyles.Any, CultureInfo.InvariantCulture, out _) &&
                // Skip short date-like strings (e.g., "2/22/2026") but not pod names with slashes
                !(nameCell.Length <= 12 && DateTime.TryParse(nameCell, CultureInfo.InvariantCulture, DateTimeStyles.None, out _)) &&
                LooksLikePodName(nameCell))
            {
                return nameCell;
            }
        }

        // Fallback: scan the full row for a pod-like label
        foreach (var cell in cells)
        {
            string val = cell?.Trim() ?? "";
            if (string.IsNullOrEmpty(val)) continue;
            if (val.Length < 4) continue;
            if (_skipKeywords.Contains(val)) continue;
            if (val.StartsWith("$") || val.StartsWith("#") || val.EndsWith("%")) continue;
            // Skip pure numbers (e.g., "1411")
            if (double.TryParse(val.Replace(",", ""), NumberStyles.Any, CultureInfo.InvariantCulture, out _)) continue;
            // Skip short date-like strings (e.g., "2/22/2026") but not pod names with slashes
            if (val.Length <= 12 && DateTime.TryParse(val, CultureInfo.InvariantCulture, DateTimeStyles.None, out _)) continue;

            if (LooksLikePodName(val))
                return val;
        }
        return null;
    }

    private bool LooksLikePodName(string val)
    {
        // Explicit alias whitelist - no dash required
        if (_podAliases.ContainsKey(val)) return true;

        // Employee names never contain a dash; all real pod headers do.
        // Require a dash before any DB lookup or heuristic so stale DB entries
        // (e.g. "Matthew Soto Velez" stored as a Department) are never matched.
        if (!val.Contains("-")) return false;

        if (PodExistsInSystem(val)) return true;

        // Fuzzy match to existing pod (handles typos like "Advisros")
        if (_allPodMembers != null)
        {
            var existingPods = _allPodMembers.Select(m => m.Department).Distinct(StringComparer.OrdinalIgnoreCase);
            if (existingPods.Any(p => FuzzyMatch(val, p)))
                return true;
        }

        // Heuristic keywords - dash already confirmed above
        string lower = val.ToLowerInvariant();
        bool hasLeaderName = lower.Contains("matt") || lower.Contains("drew") || lower.Contains("luis") || lower.Contains("jamie");
        bool hasPodKeyword = lower.Contains("pod") || lower.Contains("front") || lower.Contains("advisor") || lower.Contains("computing")
            || lower.Contains("beast") || lower.Contains("flex") || lower.Contains("mobile") || lower.Contains("category")
            || lower.Contains("crew") || lower.Contains("end");
        if (hasLeaderName || hasPodKeyword)
            return true;

        return false;
    }

    private string ResolvePodName(string excelName)
    {
        // Direct alias match
        if (_podAliases.TryGetValue(excelName, out var systemName))
            return systemName;

        // Exact match to existing pod
        if (PodExistsInSystem(excelName))
            return excelName;

        // Fuzzy match against existing pods (handles typos like "Advisros" → "Advisors")
        if (_allPodMembers != null)
        {
            var existingPods = _allPodMembers.Select(m => m.Department).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
            foreach (var existing in existingPods)
            {
                if (FuzzyMatch(excelName, existing))
                {
                    _parseLog.Add($"⚠ Fuzzy matched '{excelName}' → '{existing}' (possible typo in Excel)");
                    return existing;
                }
            }
        }

        return excelName;
    }

