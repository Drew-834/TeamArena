@page "/podtracker"
@namespace GameScoreboard.Pages
@using GameScoreboard.Models
@using GameScoreboard.Services
@using GameScoreboard.Services.Tracking
@using GameScoreboard.Data
@using System.Globalization

@inject IDataService DataService
@inject IJSRuntime JSRuntime
@inject AppState AppState

<div class="min-h-screen p-6 md:p-8" style="color: var(--er-text);">

    @if (!_isAuthenticated)
    {
        <div id="password-modal" class="elden-modal-backdrop @(_showPasswordModal ? "" : "hidden")">
            <div class="elden-modal">
                <h2 class="elden-modal-title">Sealed Passage</h2>
                <div class="elden-divider-ornate mb-4"></div>
                <div class="mb-4">
                    <input type="password" @bind="PasswordInputValue" @bind:event="oninput" @onkeydown="HandlePasswordKeydown"
                           class="elden-input w-full"
                           placeholder="Password" />
                </div>
                @if (!string.IsNullOrEmpty(_passwordError))
                {
                    <p class="text-sm mb-4" style="color: var(--er-red-bright);">@_passwordError</p>
                }
                <button @onclick="CheckPassword" class="elden-btn elden-btn-primary w-full text-center">Authenticate</button>
            </div>
        </div>
    }
    else
    {
        <div class="mx-auto max-w-[1680px] space-y-8 tracker-desktop-shell">
            <section class="elden-dashboard-section elden-dashboard-hero elden-lively-panel tracker-command-overview animate-fade-in-up">
                <div class="relative z-10 tracker-command-grid">
                    <div class="tracker-command-copy">
                        <div class="space-y-3">
                            <div class="elden-dashboard-eyebrow">Leader Dashboard</div>
                            <h1 class="font-heading text-3xl md:text-5xl" style="color: var(--er-gold-bright);">Tracker Command Chamber</h1>
                            <p class="font-body text-lg tracker-command-summary" style="color: var(--er-text-dim);">
                                Read business pressure first, then descend into the live ingest and save workflow only when the chamber calls for action.
                            </p>
                        </div>

                        <div class="tracker-command-pills">
                            <div class="tracker-command-pill">
                                <span class="tracker-command-pill-label">Scope</span>
                                <span class="tracker-command-pill-value">@GetLeadershipScopeLabel()</span>
                            </div>
                            <div class="tracker-command-pill">
                                <span class="tracker-command-pill-label">Primary Focus</span>
                                <span class="tracker-command-pill-value">@GetPrimaryPressureMetricLabel()</span>
                            </div>
                            <div class="tracker-command-pill">
                                <span class="tracker-command-pill-label">Operations</span>
                                <span class="tracker-command-pill-value">@GetImportReadinessLabel()</span>
                            </div>
                        </div>

                        <div class="tracker-command-callouts">
                            <div class="tracker-callout-card">
                                <div class="tracker-callout-label">Pressure Lane</div>
                                <div class="tracker-callout-value">@GetPrimaryPressureMetricLabel()</div>
                                <div class="tracker-callout-copy">@GetPrimaryPressureCaption()</div>
                            </div>
                            <div class="tracker-callout-card">
                                <div class="tracker-callout-label">At-Risk Champions</div>
                                <div class="tracker-callout-value">@GetFocusChampionCount()</div>
                                <div class="tracker-callout-copy">Distinct champions currently appearing across all active focus lanes.</div>
                            </div>
                            <div class="tracker-callout-card">
                                <div class="tracker-callout-label">Parse Warnings</div>
                                <div class="tracker-callout-value">@GetParseWarningCount()</div>
                                <div class="tracker-callout-copy">Warnings or errors that still need review before a live write.</div>
                            </div>
                        </div>
                    </div>

                    <div class="tracker-hero-stack">
                        <div class="elden-dashboard-grid metrics w-full tracker-hero-grid">
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Reporting Period</div>
                                <div class="elden-dashboard-value">@_selectedPeriod</div>
                                <div class="elden-dashboard-caption">Current live save label</div>
                            </div>
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Teams In Command</div>
                                <div class="elden-dashboard-value">@_pods.Count</div>
                                <div class="elden-dashboard-caption">Pods with active or staged data</div>
                            </div>
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Strategic Pressure</div>
                                <div class="elden-dashboard-value">@GetFocusPressureCount()</div>
                                <div class="elden-dashboard-caption">KPI lanes currently off track</div>
                            </div>
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Import Readiness</div>
                                <div class="elden-dashboard-value">@GetImportReadinessLabel()</div>
                                <div class="elden-dashboard-caption">@GetImportReadinessCaption()</div>
                            </div>
                        </div>

                        <div class="tracker-health-band">
                            <div class="tracker-health-card">
                                <div class="tracker-health-label">Business Health</div>
                                <div class="tracker-health-value">@GetBusinessHealthLabel()</div>
                                <div class="tracker-health-copy">@GetBusinessHealthCaption()</div>
                            </div>
                            <div class="tracker-health-card">
                                <div class="tracker-health-label">Review Focus</div>
                                <div class="tracker-health-value">@GetLeadershipScopeLabel()</div>
                                <div class="tracker-health-copy">@GetSelectionSummary()</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="tracker-focus-shell">
                <div class="elden-dashboard-section tracker-focus-stage">
                    <div class="elden-dashboard-section-header">
                        <div>
                            <div class="elden-dashboard-eyebrow">Focus Five</div>
                            <h2 class="elden-dashboard-section-title tracker-focus-title">Strategic Pressure Board</h2>
                            <p class="elden-dashboard-section-copy">
                                Highest-impact off-track KPI lanes across the current scope, ordered by live business pressure and weighted importance.
                            </p>
                        </div>
                        <div class="tracker-focus-context">
                            <span class="tracker-focus-context-label">Current Scope</span>
                            <span class="tracker-focus-context-value">@GetLeadershipScopeLabel()</span>
                        </div>
                    </div>

                    @if (GetOrderedFocusLanes().Any())
                    {
                        var orderedLanes = GetOrderedFocusLanes();
                        var focusCarousel = BuildFocusCarouselVisual(orderedLanes);

                        <div class="tracker-focus-carousel-stage">
                            <div class="tracker-focus-carousel-shell">
                                <div class="tracker-focus-carousel-header">
                                    <div class="tracker-focus-carousel-kicker">KPI Constellations</div>
                                    <div class="tracker-focus-carousel-meta">
                                        <span>@focusCarousel.Slides.Count active slides</span>
                                        <span>@GetFocusPressureCount() lanes under pressure</span>
                                    </div>
                                </div>

                                <div class="tracker-focus-guide-rail" role="tablist" aria-label="Focus Five KPI guide">
                                    @foreach (var slide in focusCarousel.Slides.Select((item, index) => new { Item = item, Index = index }))
                                    {
                                        <button type="button"
                                                class="tracker-focus-guide-btn @(slide.Index == 0 ? "is-active" : "")"
                                                data-carousel-index="@slide.Index"
                                                role="tab"
                                                aria-selected="@(slide.Index == 0 ? "true" : "false")"
                                                aria-label="@($"Focus {slide.Item.Label}")">
                                            <span class="tracker-focus-guide-rank">@($"{slide.Index + 1:D2}")</span>
                                            <span class="tracker-focus-guide-name">@slide.Item.Label</span>
                                        </button>
                                    }
                                </div>

                                <div class="champion-carousel tracker-focus-carousel" id="focus-five-carousel" data-snap="true">
                                    <div class="carousel-track tracker-focus-carousel-track">
                                        @foreach (var slide in focusCarousel.Slides)
                                        {
                                            <article class="tracker-focus-slide" @key="slide.MetricKey">
                                                <FocusFiveSigil Slide="slide" CssClass="tracker-focus-skill-tree" />
                                            </article>
                                        }
                                    </div>

                                    <div class="carousel-slider-wrap tracker-focus-carousel-slider-wrap">
                                        <input type="range"
                                               id="focus-five-slider"
                                               class="carousel-slider tracker-focus-carousel-slider"
                                               min="0"
                                               max="1000"
                                               value="0" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="font-body" style="color: var(--er-text-muted);">No off-track pressure detected yet. Load live metrics or select a team to focus the chamber.</p>
                    }
                </div>

                <aside class="elden-dashboard-section tracker-rankings-stage">
                    <div class="elden-dashboard-section-header">
                        <div>
                            <div class="elden-dashboard-eyebrow">War Council</div>
                            <h2 class="elden-dashboard-section-title">Ranking Snapshot</h2>
                            <p class="elden-dashboard-section-copy">Compact standings for context while Focus Five remains the main dashboard voice.</p>
                        </div>
                    </div>

                    @if (GetCouncilLeader() is PodStandingRow councilLeader)
                    {
                        <div class="tracker-council-leader">
                            <div class="tracker-council-leader-label">Council Lead</div>
                            <div class="tracker-council-leader-name">#@councilLeader.Rank @councilLeader.Pod</div>
                            <div class="tracker-council-leader-score">@councilLeader.Score.ToString("F1")</div>
                            <div class="tracker-council-leader-copy">@councilLeader.ChampionCount champions contributing to the live average.</div>
                        </div>
                    }

                    @if (GetPodStandingRows().Any())
                    {
                        <ol class="tracker-standings-list">
                            @foreach (var standing in GetPodStandingRows().Take(5))
                            {
                                <li class="tracker-standings-row">
                                    <div class="tracker-standings-copy">
                                        <span class="tracker-standings-rank">#@standing.Rank</span>
                                        <span class="tracker-standings-name">@standing.Pod</span>
                                    </div>
                                    <div class="tracker-standings-score">@standing.Score.ToString("F1")</div>
                                </li>
                            }
                        </ol>
                    }
                    else
                    {
                        <p class="font-body italic" style="color: var(--er-text-muted);">No ranking data yet.</p>
                    }

                    @if (GetSelectedPodLeaders().Any())
                    {
                        <div class="tracker-selected-podium">
                            <div class="tracker-selected-podium-label">@(_selectedPod ?? "Selected Team") podium</div>
                            @foreach (var leader in GetSelectedPodLeaders())
                            {
                                <div class="tracker-selected-podium-row">
                                    <span>@leader.Rank. @leader.Name</span>
                                    <span>@leader.Score.ToString("F1")</span>
                                </div>
                            }
                        </div>
                    }

                    @{
                        var sidebarFocusCarousel = BuildFocusCarouselVisual(GetOrderedFocusLanes());
                    }
                    @if (sidebarFocusCarousel.Slides.Any())
                    {
                        @foreach (var slide in sidebarFocusCarousel.Slides.Select((item, index) => new { Item = item, Index = index }))
                        {
                            <section class="tracker-focus-sidebar @(slide.Index == 0 ? "is-active" : "")"
                                     data-carousel-panel-index="@slide.Index">
                                <div class="tracker-focus-sidebar-header">
                                    <div>
                                        <div class="elden-dashboard-eyebrow">Focus Five</div>
                                        <h3 class="tracker-focus-sidebar-title">@slide.Item.Label Influence</h3>
                                    </div>
                                    <div class="tracker-focus-sidebar-meta">@slide.Item.Nodes.Count focuses</div>
                                </div>

                                <ol class="tracker-focus-sidebar-list">
                                    @foreach (var node in slide.Item.Nodes.Take(5))
                                    {
                                        <li class="tracker-focus-sidebar-row @GetFocusSeverityClassToken(node.Severity)">
                                            <div class="tracker-focus-sidebar-copy">
                                                <span class="tracker-focus-sidebar-name">@node.Name</span>
                                                <span class="tracker-focus-sidebar-context">@slide.Item.Label • @node.Pod</span>
                                            </div>
                                            <div class="tracker-focus-sidebar-stats">
                                                <span class="tracker-focus-sidebar-delta">@node.DeltaLabel</span>
                                                <span class="tracker-focus-sidebar-impact">Impact @node.ImpactLabel</span>
                                            </div>
                                        </li>
                                    }
                                </ol>
                            </section>
                        }
                    }
                </aside>
            </section>

            <section class="tracker-operations-band">
                <div class="tracker-operations-intro">
                    <div class="elden-dashboard-eyebrow">Operations / Live Writes</div>
                    <h2 class="tracker-operations-title">Import, review, and commit tracker changes</h2>
                    <p class="tracker-operations-copy">Once the dashboard has framed the pressure, use the lower chamber to ingest the tracker, review staged pod data, and commit direct edits.</p>
                </div>

                <div class="tracker-operations-layout">
                    <section class="elden-dashboard-section tracker-import-stage">
                        <div class="elden-dashboard-section-header">
                            <div>
                                <div class="elden-dashboard-eyebrow">Import Flow</div>
                                <h2 class="elden-dashboard-section-title">Ingest The Tracker</h2>
                                <p class="elden-dashboard-section-copy">Paste the dashboard output, inspect parsing feedback, then commit staged team updates when the chamber looks clean.</p>
                            </div>
                        </div>

                        <div class="elden-dashboard-grid triple mb-5">
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Parsed Teams</div>
                                <div class="elden-dashboard-value">@GetParsedTeamCount()</div>
                                <div class="elden-dashboard-caption">Teams recognized in the current paste</div>
                            </div>
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Roster Matches</div>
                                <div class="elden-dashboard-value">@GetParsedMatchedCount()</div>
                                <div class="elden-dashboard-caption">Members aligned with existing champions</div>
                            </div>
                            <div class="elden-dashboard-card">
                                <div class="elden-dashboard-eyebrow">Warnings</div>
                                <div class="elden-dashboard-value">@GetParseWarningCount()</div>
                                <div class="elden-dashboard-caption">Rows needing review before a live save</div>
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-4 mb-4 items-end">
                            <div>
                                <label class="block text-sm font-body mb-1" style="color: var(--er-text-dim);">Upload Date</label>
                                <div class="px-4 py-2 font-mono font-semibold rounded-xl" style="background: var(--er-bg-card); border: 1px solid var(--er-border); color: var(--er-gold);">
                                    @_selectedPeriod
                                </div>
                            </div>
                            <p class="text-sm pb-1" style="color: var(--er-text-muted);">Period is auto-set to today's date and used for all live writes and backups.</p>
                        </div>

                        <div class="mb-4">
                            <label class="block text-sm font-body mb-2" style="color: var(--er-text-dim);">
                                Paste Full Excel Sheet
                                <span style="color: var(--er-text-muted);">(copy all rows including team headers)</span>
                            </label>
                            <textarea @bind="_pastedData" @bind:event="oninput" rows="10"
                                      class="elden-input w-full font-mono text-sm"
                                      placeholder="Select all data in the Excel tracker (Ctrl+A) and paste here (Ctrl+V)..."></textarea>
                        </div>

                        <div class="flex flex-wrap items-center gap-4">
                            <button @onclick="HandlePastedData" disabled="@_isParsing" class="elden-btn elden-btn-primary">
                                @(_isParsing ? "Processing..." : "Process Pasted Data")
                            </button>
                            @if (!string.IsNullOrEmpty(_uploadStatusMessage))
                            {
                                <span class="text-sm" style="color: @(_uploadSuccess ? "var(--er-green-bright)" : "var(--er-red-bright)");">@_uploadStatusMessage</span>
                            }
                        </div>

                        @if (_parseResults != null && _parseResults.Any())
                        {
                            <div class="mt-5 elden-grid-shell">
                                <h3 class="font-heading text-sm mb-4" style="color: var(--er-gold);">Staged Parse Results</h3>

                                @foreach (var pod in _parseResults)
                                {
                                    <div class="mb-3 p-4 rounded-2xl cursor-pointer elden-dashboard-card"
                                         @onclick="() => SelectPodFromResults(pod.SystemName)">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span style="color: @(pod.IsNew ? "var(--er-blue-bright)" : "var(--er-green-bright)");" class="text-lg">@(pod.IsNew ? "★" : "✓")</span>
                                            <span class="font-semibold">@pod.ExcelName</span>
                                            @if (pod.ExcelName != pod.SystemName)
                                            {
                                                <span style="color: var(--er-text-muted);">→</span>
                                                <span style="color: var(--er-gold);">@pod.SystemName</span>
                                            }
                                            @if (pod.IsNew)
                                            {
                                                <span class="text-xs px-2 py-0.5 rounded" style="background: var(--er-blue); color: var(--er-text);">NEW TEAM</span>
                                            }
                                            <span class="text-sm ml-auto" style="color: var(--er-text-dim);">
                                                @(pod.MatchedMembers.Count + pod.NewMembers.Count) members
                                                @if (pod.NewMembers.Any()) { <span style="color: var(--er-blue-bright);">(@pod.NewMembers.Count new)</span> }
                                            </span>
                                        </div>
                                        @if (pod.NewMembers.Any())
                                        {
                                            <div class="text-xs mt-2 ml-7" style="color: var(--er-blue-bright);">New: @string.Join(", ", pod.NewMembers)</div>
                                        }
                                        @if (pod.UnmatchedNames.Any())
                                        {
                                            <div class="text-xs mt-1 ml-7" style="color: var(--er-bronze);">Could not match: @string.Join(", ", pod.UnmatchedNames)</div>
                                        }
                                    </div>
                                }

                                @if (_parseLog.Any())
                                {
                                    <details class="mt-4">
                                        <summary class="text-sm cursor-pointer" style="color: var(--er-text-dim);">Detailed parse log (@_parseLog.Count entries)</summary>
                                        <div class="mt-2 p-3 rounded text-xs font-mono max-h-48 overflow-y-auto space-y-0.5" style="background: var(--er-bg-primary);">
                                            @foreach (var log in _parseLog)
                                            {
                                                string logColor = log.StartsWith("⚠") ? "var(--er-gold)" : log.StartsWith("★") ? "var(--er-blue-bright)" : log.StartsWith("✗") ? "var(--er-red-bright)" : "var(--er-green-bright)";
                                                <div style="color: @logColor;">@log</div>
                                            }
                                        </div>
                                    </details>
                                }

                                @if (_parsedPodData.Any())
                                {
                                    <div class="mt-4 flex flex-wrap gap-3">
                                        <button @onclick="SaveAllPods" disabled="@_isSaving" class="elden-btn elden-btn-primary">
                                            @(_isSaving ? "Saving All..." : $"Save All {_parsedPodData.Count} Teams")
                                        </button>
                                        <button @onclick="ClearParseResults" class="elden-btn">Clear Results</button>
                                    </div>
                                }
                            </div>
                        }
                    </section>

                    <section class="elden-dashboard-section tracker-review-stage">
                        <div class="elden-dashboard-section-header">
                            <div>
                                <div class="elden-dashboard-eyebrow">Edit / Review</div>
                                <h2 class="elden-dashboard-section-title">Roster Review Table</h2>
                                <p class="elden-dashboard-section-copy">Choose a pod, review the applicable KPI profile, then stage or save direct adjustments for the selected team.</p>
                            </div>
                            <div class="w-full max-w-sm">
                                <select class="elden-select text-sm w-full" @onchange="OnPodChanged">
                                    <option value="">Select Team...</option>
                                    @foreach (var pod in _pods)
                                    {
                                        <option value="@pod" selected="@(pod == _selectedPod)">@pod</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="elden-chip-list mb-5">
                            @foreach (var metricKey in GetCurrentMetricDisplayKeys())
                            {
                                <div class="elden-metric-chip">
                                    <div class="elden-metric-chip-name">@TeamMember.GetMetricDisplayName(metricKey)</div>
                                    <div class="elden-metric-chip-meta">
                                        <span>Weight @PodMetricCatalog.GetWeight(metricKey)</span>
                                        <span>Goal @FormatMetricTarget(metricKey)</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="elden-grid-shell overflow-x-auto">
                            <div class="flex items-center justify-between mb-3">
                                <h3 class="font-heading text-lg" style="color: var(--er-gold);">
                                    @(_selectedPod ?? "Select a Team")
                                    @if (_parsedPodData.ContainsKey(_selectedPod ?? ""))
                                    {
                                        <span class="text-sm ml-2" style="color: var(--er-green-bright);">(data loaded)</span>
                                    }
                                </h3>
                                @if (!string.IsNullOrEmpty(_selectedPod))
                                {
                                    <span class="text-sm font-body" style="color: var(--er-text-dim);">@GetSelectionSummary()</span>
                                }
                            </div>

                            @if (_currentPodMembers != null && _currentPodMembers.Any() && !string.IsNullOrEmpty(_selectedPod))
                            {
                                <table class="elden-table min-w-[900px]">
                                    <thead>
                                        <tr>
                                            <th class="text-left sticky left-0 z-10" style="background: var(--er-bg-secondary);">Name</th>
                                            @foreach (var metricKey in _podMetricKeys)
                                            {
                                                <th class="text-center">@TeamMember.GetMetricDisplayName(metricKey)</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in _currentPodMembers.OrderBy(m => m.Name))
                                        {
                                            <tr>
                                                <td class="font-medium sticky left-0 z-10" style="background: var(--er-bg-panel);">@member.Name</td>
                                                @foreach (var metricKey in _podMetricKeys)
                                                {
                                                    <td>
                                                        <input type="text"
                                                               class="elden-input w-full text-center font-mono"
                                                               placeholder="-"
                                                               @bind="_inputValues[member.Id][metricKey]"
                                                               @bind:event="oninput" />
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else if (!string.IsNullOrEmpty(_selectedPod))
                            {
                                <p class="font-body" style="color: var(--er-text-muted);">No team members found for this team.</p>
                            }
                            else
                            {
                                <p class="font-body" style="color: var(--er-text-muted);">Select a team above or paste data to get started.</p>
                            }
                        </div>

                        <div class="mt-6 flex flex-wrap items-center justify-end gap-4">
                            <button @onclick="SaveMetrics" disabled="@(_isSaving || string.IsNullOrEmpty(_selectedPod))" class="elden-btn elden-btn-primary">
                                @(_isSaving ? "Saving..." : "Save Current Team")
                            </button>
                            <button @onclick="ClearInputs" class="text-sm underline" style="color: var(--er-text-dim);">Clear Inputs</button>
                        </div>
                        @if (!string.IsNullOrEmpty(_saveSuccessMessage))
                        {
                            <div class="elden-notification success mt-3 text-sm">@_saveSuccessMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(_saveError))
                        {
                            <div class="elden-notification error mt-2 text-sm">@_saveError</div>
                        }
                    </section>
                </div>
            </section>
        </div>
    }
</div>

@code {
    // ── Auth state ──
    private bool _isAuthenticated = false;
    private bool _showPasswordModal = false;
    private string _passwordInput = string.Empty;
    private string _passwordError = string.Empty;
    private const string CorrectPassword = "Admin321"; // Keep leadership/back-office tracker access on Admin321 unless the user explicitly requests a change.

    // ── Page state ──
    private bool _isSaving = false;
    private bool _isParsing = false;
    private string? _saveError = null;
    private string? _saveSuccessMessage = null;
    private string? _uploadStatusMessage = null;
    private bool _uploadSuccess = false;
    private string _pastedData = string.Empty;

    // ── Data ──
    private List<string> _pods = new();
    private string? _selectedPod;
    private string _selectedPeriod = DateTime.Today.ToString("yyyy-MM-dd");
