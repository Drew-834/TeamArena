    // ── Save: current pod ──
    private async Task SaveMetrics()
    {
        if (_isSaving) return;
        _isSaving = true; _saveError = null; _saveSuccessMessage = null;

        if (_currentPodMembers == null || string.IsNullOrEmpty(_selectedPod))
        { _saveError = "Team must be selected."; _isSaving = false; StateHasChanged(); return; }

        try
        {
            await SavePodMembers(_currentPodMembers, _inputValues);
            await AppState.NotifyMetricsUpdatedAsync();
            await ReloadAllPodMembersAsync();
            LoadMembersForSelectedPod();
            CalculateAllRankings();
            CalculateFocusFive();

            // Auto-backup
            await AutoBackupPod(_selectedPod);

            _saveSuccessMessage = $"Saved and backed up metrics for {_selectedPod}!";
        }
        catch (Exception ex)
        {
            _saveError = $"Error: {ex.Message}";
        }
        finally { _isSaving = false; StateHasChanged(); }
    }

    // ── Save: all parsed pods at once ──
    private async Task SaveAllPods()
    {
        if (_isSaving || string.IsNullOrEmpty(_selectedPeriod)) return;
        _isSaving = true; _saveError = null; _saveSuccessMessage = null;
        StateHasChanged();

        int savedPods = 0;
        int savedMembers = 0;
        var errors = new List<string>();

        try
        {
            var parsedPodNames = _parsedPodData.Keys.ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var (podName, podData) in _parsedPodData)
            {
                var podMembers = _allPodMembers?
                    .Where(m => m.Department.Equals(podName, StringComparison.OrdinalIgnoreCase))
                    .ToList() ?? new();

                if (!podMembers.Any()) continue;

                var podInputs = new Dictionary<int, Dictionary<string, string>>();
                foreach (var (memberId, values) in podData)
                {
                    if (podMembers.Any(m => m.Id == memberId))
                        podInputs[memberId] = values;
                }

                try
                {
                    await SavePodMembers(podMembers.Where(m => podInputs.ContainsKey(m.Id)).ToList(), podInputs);

                    var omittedMembers = podMembers
                        .Where(m => !podInputs.ContainsKey(m.Id))
                        .ToList();
                    foreach (var omitted in omittedMembers)
                    {
                        await DataService.SaveMetricRecordsForPeriodAsync(omitted.Id, _selectedPeriod!, new List<MetricRecord>());
                    }

                    savedPods++;
                    savedMembers += podInputs.Count;
                }
                catch (Exception ex)
                {
                    errors.Add($"{podName}: {ex.Message}");
                }
            }

            var stalePodMembers = (_allPodMembers ?? new List<TeamMember>())
                .Where(m => PodMetricCatalog.IsPodDepartment(m.Department) && !parsedPodNames.Contains(m.Department))
                .ToList();

            foreach (var staleMember in stalePodMembers)
            {
                await DataService.SaveMetricRecordsForPeriodAsync(staleMember.Id, _selectedPeriod!, new List<MetricRecord>());
            }

            CalculateAllRankings();
            await AppState.NotifyMetricsUpdatedAsync();
            await ReloadAllPodMembersAsync();
            LoadMembersForSelectedPod();
            CalculateFocusFive();

            // Auto-backup: create snapshot for each saved pod
            int backupCount = 0;
            try
            {
                var freshMembers = (await DataService.GetTeamMembersAsync())?.ToList() ?? new();
                foreach (var podName in _parsedPodData.Keys)
                {
                    var podMembers = freshMembers
                        .Where(m => m.Department.Equals(podName, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    if (!podMembers.Any()) continue;

                    var snapshotData = podMembers.Select(m => new
                    {
                        m.Name, m.Id,
                        WeightedScore = GetWeightedScoreForMember(m).ToString("F1", CultureInfo.InvariantCulture),
                        Metrics = _podMetricKeys.ToDictionary(k => k, k =>
                        {
                            var rec = m.MetricRecords?.FirstOrDefault(r => r.MetricKey.Equals(k, StringComparison.OrdinalIgnoreCase));
                            return rec?.Value ?? "—";
                        })
                    }).ToList();

                    await DataService.SavePodSnapshotAsync(new GameScoreboard.Models.PodSnapshot
                    {
                        PodName = podName,
                        Label = _selectedPeriod,
                        JsonData = System.Text.Json.JsonSerializer.Serialize(snapshotData)
                    });
                    backupCount++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PodTracker] Auto-backup error: {ex.Message}");
            }

            // Clean up stale duplicate records from the DB so all views show accurate data
            int removedDuplicates = await DataService.CleanupDuplicatesAsync();
            if (removedDuplicates > 0)
            {
                _parseLog.Add($"Cleaned up {removedDuplicates} duplicate member record(s) from database.");
                AppState.InvalidateCache();
            }

            _saveSuccessMessage = $"Saved {savedMembers} members across {savedPods} teams! Auto-backed up {backupCount} teams.";
            if (removedDuplicates > 0) _saveSuccessMessage += $" Removed {removedDuplicates} stale duplicates.";
            if (errors.Any())
                _saveError = $"Errors in: {string.Join("; ", errors)}";
        }
        catch (Exception ex)
        {
            _saveError = $"Error: {ex.Message}";
        }
        finally { _isSaving = false; StateHasChanged(); }
    }

    private async Task SavePodMembers(List<TeamMember> members, Dictionary<int, Dictionary<string, string>> inputValues)
    {
        var updateTasks = new List<Task>();

        foreach (var member in members)
        {
            if (!inputValues.TryGetValue(member.Id, out var memberInputs)) continue;

            bool hasAnyValue = memberInputs.Values.Any(v => !string.IsNullOrWhiteSpace(v));
            if (!hasAnyValue) continue;

            var records = new List<MetricRecord>();
            double totalWeightedScore = 0;
            int applicableWeight = 0;
            var applicableMetrics = GetMetricsForDepartment(member.Department);

            foreach (var metricKey in _podMetricKeys)
            {
                string rawVal = memberInputs.GetValueOrDefault(metricKey, "")?.Trim() ?? "";
                records.Add(new MetricRecord { TeamMemberId = member.Id, Period = _selectedPeriod!, MetricKey = metricKey, Value = rawVal });

                if (!applicableMetrics.Contains(metricKey))
                {
                    continue;
                }

                if (double.TryParse(rawVal, NumberStyles.Any, CultureInfo.InvariantCulture, out double numVal))
                {
                    int weight = PodMetricCatalog.GetWeight(metricKey);
                    double normalized;

                    if (metricKey == "Surveys" && numVal == 0)
                        normalized = 0;
                    else if ((metricKey == "AppEff" || metricKey == "PMEff"))
                    {
                        double target = PodMetricCatalog.GetTarget(metricKey);
                        normalized = target > 0 && numVal > 0 && numVal < 20000 ? (target / numVal) * 100.0 : 0;
                    }
                    else
                    {
                        double target = PodMetricCatalog.GetTarget(metricKey);
                        normalized = target > 0 ? (numVal / target) * 100.0 : 0;
                    }

                    if (normalized > 100)
                    {
                        double excess = normalized - 100;
                        double bonus = 15.0 * Math.Log(1 + excess / 20.0);
                        normalized = 100 + Math.Min(bonus, 25.0);
                    }

                    normalized = Math.Clamp(normalized, 0, 125);
                    totalWeightedScore += normalized * weight;
                    applicableWeight += weight;
                }
            }

            var existingRecords = await DataService.GetMetricRecordsAsync(memberId: member.Id, period: _selectedPeriod!);
            bool alreadyHadData = existingRecords != null && existingRecords.Any();

            updateTasks.Add(DataService.SaveMetricRecordsForPeriodAsync(member.Id, _selectedPeriod!, records));

            bool shouldPersistMember = _membersPendingDepartmentUpdate.Contains(member.Id);
            if (applicableWeight > 0 && !alreadyHadData)
            {
                const double xpMultiplier = 0.25;
                const double performanceGate = 50.0;
                double avgScore = totalWeightedScore / applicableWeight;
                double xpAwarded = avgScore >= performanceGate ? avgScore * xpMultiplier : 0;
                member.TotalExperience += xpAwarded;
                shouldPersistMember = true;
            }

            if (shouldPersistMember)
            {
                updateTasks.Add(DataService.UpdateTeamMemberAsync(member));
            }
        }

        await Task.WhenAll(updateTasks);
        foreach (var member in members)
        {
            _membersPendingDepartmentUpdate.Remove(member.Id);
        }

        // Sync XP to master list
        if (_allPodMembers != null)
        {
            foreach (var updated in members)
            {
                var global = _allPodMembers.FirstOrDefault(m => m.Id == updated.Id);
                if (global != null) global.TotalExperience = updated.TotalExperience;
            }
        }
    }

    private async Task AutoBackupPod(string podName)
    {
        try
        {
            var freshMembers = (await DataService.GetTeamMembersAsync())?.ToList() ?? new();
            var podMembers = freshMembers
                .Where(m => m.Department.Equals(podName, StringComparison.OrdinalIgnoreCase))
                .ToList();
            if (!podMembers.Any()) return;

            var snapshotData = podMembers.Select(m => new
            {
                m.Name, m.Id,
                WeightedScore = GetWeightedScoreForMember(m).ToString("F1", CultureInfo.InvariantCulture),
                Metrics = _podMetricKeys.ToDictionary(k => k, k =>
                {
                    var rec = m.MetricRecords?.FirstOrDefault(r => r.MetricKey.Equals(k, StringComparison.OrdinalIgnoreCase));
                    return rec?.Value ?? "—";
                })
            }).ToList();

            await DataService.SavePodSnapshotAsync(new GameScoreboard.Models.PodSnapshot
            {
                PodName = podName,
                Label = _selectedPeriod,
                JsonData = System.Text.Json.JsonSerializer.Serialize(snapshotData)
            });
            Console.WriteLine($"[PodTracker] Auto-backup saved for pod '{podName}'");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PodTracker] Auto-backup error for '{podName}': {ex.Message}");
        }
    }

    private double GetWeightedScoreForMember(TeamMember member)
    {
        double totalWeightedScore = 0;
        int applicableWeight = 0;
        var metricsForMember = GetMetricsForDepartment(member.Department);
        foreach (var metricKey in metricsForMember)
        {
            int weight = PodMetricCatalog.GetWeight(metricKey);
            var rec = member.MetricRecords?.FirstOrDefault(r => r.MetricKey.Equals(metricKey, StringComparison.OrdinalIgnoreCase));
            if (rec?.Value == null || !double.TryParse(rec.Value, NumberStyles.Any, CultureInfo.InvariantCulture, out double numVal))
                continue;
            if ((metricKey == "AppEff" || metricKey == "PMEff") && numVal >= 20000) continue;
            double target = PodMetricCatalog.GetTarget(metricKey);
            double normalized;
            if (metricKey == "Surveys" && numVal == 0)
                normalized = 0;
            else if (metricKey == "AppEff" || metricKey == "PMEff")
                normalized = target > 0 && numVal > 0 ? (target / numVal) * 100.0 : 0;
            else
                normalized = target > 0 ? (numVal / target) * 100.0 : 0;

            if (normalized > 100)
            {
                double excess = normalized - 100;
                double bonus = 15.0 * Math.Log(1 + excess / 20.0);
                normalized = 100 + Math.Min(bonus, 25.0);
            }

            normalized = Math.Clamp(normalized, 0, 125);
            totalWeightedScore += normalized * weight;
            applicableWeight += weight;
        }
        return applicableWeight > 0 ? Math.Min(totalWeightedScore / applicableWeight, 125) : 0;
    }

    // ── Focus 5: highest-impact off-track individuals per KPI ──
    private void CalculateFocusFive()
    {
        _focusFiveByKpi = new Dictionary<string, List<FocusFiveEntry>>();
        _focusCarouselInitialized = false;
        if (_allPodMembers == null || !_allPodMembers.Any()) return;

        var allCandidates = string.IsNullOrEmpty(_selectedPod)
            ? _allPodMembers
            : _allPodMembers.Where(m => m.Department.Equals(_selectedPod, StringComparison.OrdinalIgnoreCase)).ToList();
        var members = allCandidates.Where(m => m.MetricRecords?.Any() == true).ToList();

        double avgRph = members
            .Select(m => GetMemberLatestMetricValue(m, "RPH"))
            .Where(v => v.HasValue && v.Value > 0)
            .Select(v => v!.Value)
            .DefaultIfEmpty(920)
            .Average();

        var allRelevantMetrics = string.IsNullOrEmpty(_selectedPod)
            ? new HashSet<string>(members.SelectMany(m => GetMetricsForDepartment(m.Department)), StringComparer.OrdinalIgnoreCase)
            : new HashSet<string>(GetMetricsForDepartment(_selectedPod), StringComparer.OrdinalIgnoreCase);

        foreach (var metricKey in allRelevantMetrics)
        {
            double target = PodMetricCatalog.GetTarget(metricKey);
            int weight = PodMetricCatalog.GetWeight(metricKey);
            bool lowerIsBetter = metricKey == "AppEff" || metricKey == "PMEff";
            var entries = new List<FocusFiveEntry>();

            foreach (var m in members)
            {
                var memberMetrics = PodMetricCatalog.GetApplicableMetrics(m.Department);
                if (!memberMetrics.Contains(metricKey)) continue;

                double? val = GetMemberLatestMetricValue(m, metricKey);
                if (!val.HasValue) continue;
                if (lowerIsBetter && val.Value >= 20000) continue;

                double percentOff;
                bool isOffTrack;
                if (lowerIsBetter)
                {
                    percentOff = target > 0 ? ((val.Value - target) / target) * 100.0 : 0;
                    isOffTrack = val.Value > target;
                }
                else
                {
                    percentOff = target > 0 ? ((val.Value - target) / target) * 100.0 : 0;
                    isOffTrack = val.Value < target;
                }

                if (!isOffTrack) continue;

                double memberRph = GetMemberLatestMetricValue(m, "RPH") ?? 0;
                double rphFactor = avgRph > 0 ? memberRph / avgRph : 1.0;
                double impact = rphFactor * weight * Math.Abs(percentOff);

                entries.Add(new FocusFiveEntry
                {
                    Name = m.Name.Split(' ')[0],
                    Pod = m.Department.Length > 15 ? m.Department[..15] + "…" : m.Department,
                    PercentOff = percentOff,
                    Impact = impact
                });
            }

            _focusFiveByKpi[metricKey] = entries
                .OrderByDescending(e => e.Impact)
                .Take(5)
                .ToList();
        }
    }

    private double? GetMemberLatestMetricValue(TeamMember member, string metricKey)
    {
        foreach (var lookupKey in PodMetricCatalog.GetLookupKeys(metricKey, member.Department))
        {
            var record = member.MetricRecords?
                .Where(r => r.MetricKey.Equals(lookupKey, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(r => r.Period)
                .FirstOrDefault();
            if (record?.Value != null && double.TryParse(record.Value, NumberStyles.Any, CultureInfo.InvariantCulture, out double val))
                return val;
        }

        return null;
    }

    // ── Rankings (by live weighted KPI score) ──
    private void CalculateAllRankings()
    {
        if (_allPodMembers == null || !_allPodMembers.Any()) return;
        _podRankings = new Dictionary<string, List<RankedMember>>();

        foreach (var pod in _pods)
        {
            var membersInPod = _allPodMembers.Where(m => m.Department.Equals(pod, StringComparison.OrdinalIgnoreCase)).ToList();
            if (!membersInPod.Any()) continue;

            var ranked = membersInPod
                .Select(m => new RankedMember { Id = m.Id, Name = m.Name, Department = m.Department, Score = GetWeightedScoreForMember(m) })
                .Where(rm => rm.Score > 0)
                .OrderByDescending(rm => rm.Score)
                .Select((rm, idx) => { rm.Rank = idx + 1; return rm; })
                .ToList();

            _podRankings[pod] = ranked;
        }
        InvokeAsync(StateHasChanged);
    }

