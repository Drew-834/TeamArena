    protected override async Task OnInitializedAsync()
    {
        try
        {
            await ReloadAllPodMembersAsync();
            CalculateAllRankings();
            CalculateFocusFive();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in PodTracker init: {ex.Message}");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAllPodMembersAsync()
    {
        var allMembers = (await DataService.GetTeamMembersAsync())?.ToList() ?? new List<TeamMember>();
        _allPodMembers = allMembers
            .Where(m => !_regularDepartments.Contains(m.Department))
            .GroupBy(m => m.Name.Trim().ToLowerInvariant())
            .Select(g => g.OrderByDescending(m => m.Id).First())
            .ToList();

        _pods = _allPodMembers
            .Where(m => m.MetricRecords?.Any() == true || _parsedPodData.ContainsKey(m.Department))
            .Select(m => m.Department)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(d => d)
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Check for session timeout (30 minutes)
                var authTime = await JSRuntime.InvokeAsync<string?>("sessionStorage.getItem", "managerAuthTime");
                if (!string.IsNullOrEmpty(authTime) && long.TryParse(authTime, out long timestamp))
                {
                    var elapsed = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() - timestamp;
                    if (elapsed > 30 * 60 * 1000) // 30 minutes
                    {
                        await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "managerAuthenticated");
                        await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "managerAuthTime");
                        _isAuthenticated = false;
                        _showPasswordModal = true;
                        await InvokeAsync(StateHasChanged);
                        return;
                    }
                }

                var isAuth = await JSRuntime.InvokeAsync<string?>("sessionStorage.getItem", "managerAuthenticated");
                if (isAuth == "true") { _isAuthenticated = true; _showPasswordModal = false; await InvokeAsync(StateHasChanged); return; }
            }
            catch { }
            if (!_isAuthenticated)
            {
                await Task.Delay(50);
                _showPasswordModal = true;
                await InvokeAsync(StateHasChanged);
            }
        }

        if (_isAuthenticated && !_focusCarouselInitialized && GetOrderedFocusLanes().Any())
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("eldenCarousel.init", "focus-five-carousel", "focus-five-slider");
                _focusCarouselInitialized = true;
            }
            catch
            {
            }
        }
    }

