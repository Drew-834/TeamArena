    private FocusCarouselVisual BuildFocusCarouselVisual(IEnumerable<KeyValuePair<string, List<FocusFiveEntry>>>? lanes = null)
    {
        var orderedLanes = (lanes ?? GetOrderedFocusLanes()).ToList();
        var maxImpactAcrossBoard = orderedLanes
            .SelectMany(lane => lane.Value)
            .Select(entry => entry.Impact)
            .DefaultIfEmpty(0)
            .Max();

        return new FocusCarouselVisual
        {
            Slides = orderedLanes
                .Select((lane, slideIndex) => new FocusFiveSigil.KpiSlide
                {
                    MetricKey = lane.Key,
                    Label = TeamMember.GetMetricDisplayName(lane.Key),
                    GoalLabel = FormatMetricTarget(lane.Key),
                    Weight = _metricWeights.GetValueOrDefault(lane.Key, 0),
                    Severity = lane.Value.Any() ? Math.Abs(lane.Value[0].PercentOff) : 0,
                    SeverityLabel = GetFocusSeverityLabel(lane.Value.Any() ? Math.Abs(lane.Value[0].PercentOff) : 0),
                    SlideNumber = slideIndex + 1,
                    SlideCount = orderedLanes.Count,
                    Nodes = lane.Value
                        .Take(5)
                        .Select((entry, index) => new FocusFiveSigil.ConstellationNode
                        {
                            Name = entry.Name,
                            Pod = entry.Pod,
                            Importance = GetConstellationImportance(entry, lane.Value, index, maxImpactAcrossBoard),
                            Severity = GetConstellationSeverity(entry),
                            DeltaLabel = entry.PercentOff.ToString("+0;-0", CultureInfo.InvariantCulture) + "%",
                            ImpactLabel = entry.Impact.ToString("F0", CultureInfo.InvariantCulture)
                        })
                        .ToList()
                })
                .ToList()
        };
    }

    private static double NormalizeToHundred(double value, double max)
    {
        if (max <= 0)
        {
            return 0;
        }

        return Math.Clamp((value / max) * 100.0, 0, 100);
    }

    private double GetConstellationImportance(FocusFiveEntry entry, List<FocusFiveEntry> entries, int rankIndex, double maxImpactAcrossBoard)
    {
        var localImpact = NormalizeToHundred(entry.Impact, entries.Max(item => item.Impact <= 0 ? 1 : item.Impact));
        var globalImpact = NormalizeToHundred(entry.Impact, maxImpactAcrossBoard <= 0 ? 1 : maxImpactAcrossBoard);
        var rankBias = Math.Max(0, 100 - (rankIndex * 16));
        return Math.Clamp((localImpact * 0.45) + (globalImpact * 0.35) + (rankBias * 0.20), 0, 100);
    }

    private double GetConstellationSeverity(FocusFiveEntry entry)
    {
        return NormalizeToHundred(Math.Abs(entry.PercentOff), 45);
    }

