@page "/pods/{*PodName}"
@using GameScoreboard.Models
@using GameScoreboard.Services
@using GameScoreboard.Services.Tracking
@using GameScoreboard.Data
@using System.Globalization
@using System.Text.Json

@inject IDataService DataService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AppState AppState
@implements IDisposable

<div class="min-h-screen p-6 md:p-8" style="color: var(--er-text);">
    <div class="text-center mb-4">
        <h1 class="title-glow text-3xl md:text-4xl mb-1">@PodName</h1>
        <p class="font-body" style="color: var(--er-text-dim);">Team Performance Overview</p>
        <p class="font-mono text-xs mt-1" style="color: var(--er-text-muted);">@FormatPeriodDisplay(_latestPeriod)</p>
    </div>

    <div class="flex justify-center items-center gap-4 mb-6">
        <button @onclick="BackupToDatabase" disabled="@_isSaving" class="elden-btn">
            @(_isSaving ? "Saving..." : "Backup to Database")
        </button>
        <button @onclick="ToggleHistory" class="elden-btn">
            @(_showHistory ? "Hide History" : "View History") (@_snapshots.Count)
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_backupMessage))
    {
        <div class="elden-notification @(_backupSuccess ? "success" : "error") max-w-xl mx-auto mb-6 text-center text-sm font-body">
            @_backupMessage
        </div>
    }

    @if (_showHistory)
    {
        <div class="mb-10 elden-panel">
            <h2 class="font-heading text-xl text-center mb-4" style="color: var(--er-gold);">Performance History</h2>
            @if (_snapshots.Any())
            {
                <div class="overflow-x-auto">
                    <table class="elden-table">
                        <thead>
                            <tr>
                                <th class="text-left">#</th>
                                <th class="text-left">Date</th>
                                <th class="text-left">Label</th>
                                <th class="text-left">Members</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var snap in _snapshots)
                            {
                                bool isExpanded = _expandedSnapshotId == snap.Id;
                                <tr class="cursor-pointer" @onclick="() => ToggleSnapshotDetail(snap.Id)">
                                    <td>@snap.Id</td>
                                    <td>@snap.SnapshotDate.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</td>
                                    <td>@(snap.Label ?? "—")</td>
                                    <td>@GetSnapshotMemberCount(snap)</td>
                                    <td class="text-center">
                                        <span class="text-xs" style="color: var(--er-gold-dim);">@(isExpanded ? "▼ Collapse" : "▶ Expand")</span>
                                    </td>
                                </tr>
                                @if (isExpanded)
                                {
                                    <tr>
                                        <td colspan="5" class="p-0">
                                            <div class="p-4" style="background: var(--er-bg-primary); border: 1px solid var(--er-border);">
                                                @{ var detail = ParseSnapshotData(snap); }
                                                @if (detail != null && detail.Any())
                                                {
                                                    <div class="overflow-x-auto">
                                                        <table class="elden-table text-xs">
                                                            <thead><tr>
                                                                <th class="text-left">Name</th>
                                                                @foreach (var metricKey in GetOverviewMetrics(PodName))
                                                                {
                                                                    <th class="text-right">@TeamMember.GetMetricDisplayName(metricKey)</th>
                                                                }
                                                                <th class="text-right" style="color: var(--er-gold);">Score</th>
                                                            </tr></thead>
                                                            <tbody>
                                                                @foreach (var row in detail)
                                                                {
                                                                    <tr>
                                                                        <td class="font-medium">@row.Name</td>
                                                                        @foreach (var metricKey in GetOverviewMetrics(PodName))
                                                                        {
                                                                            <td class="text-right" style="color: var(--er-text-dim);">@row.Metrics.GetValueOrDefault(metricKey, "—")</td>
                                                                        }
                                                                        <td class="text-right font-bold" style="color: var(--er-gold);">@row.WeightedScore</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <p class="text-center font-body" style="color: var(--er-text-muted);">Could not parse snapshot data.</p>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center font-body" style="color: var(--er-text-muted);">No snapshots yet.</p>
            }
        </div>
    }

    @if (_isLoading)
    {
        <div class="flex flex-col items-center mt-16">
            <div class="elden-loading-rune mb-4"></div>
            <p class="font-heading text-sm" style="color: var(--er-gold-dim);">Loading...</p>
        </div>
    }
    else if (_teamMembers == null || !_teamMembers.Any() || string.IsNullOrEmpty(_latestPeriod))
    {
        <p class="text-center font-body" style="color: var(--er-text-muted);">No metric data available for this team.</p>
    }
    else
    {
        <!-- KPI Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
            @foreach (var metricKey in GetOverviewMetrics(PodName))
            {
                var avgData = _departmentAverages.GetValueOrDefault(metricKey);
                var highPerformer = _highPerformerNames.GetValueOrDefault(metricKey);
                var lowPerformer = _lowPerformerNames.GetValueOrDefault(metricKey);
                var goal = GetMetricGoal(metricKey);
                var weight = GetMetricWeight(metricKey);

                <div class="elden-panel elden-panel-gold">
                    <div class="flex justify-between items-center mb-2">
                        <h3 class="font-heading text-sm tracking-wide" style="color: var(--er-gold);">@TeamMember.GetMetricDisplayName(metricKey)</h3>
                        <span class="font-mono text-xs px-2 py-0.5" style="background: var(--er-bg-card); color: var(--er-text-dim); border: 1px solid var(--er-border);">@weight/32</span>
                    </div>
                    <div class="flex justify-between items-baseline mb-3">
                        @{
                            bool isEfficiency = IsLowerBetter(metricKey);
                            var statusColor = GetAverageStatusColor(avgData.Average, goal, isEfficiency);
                        }
                        <span class="font-mono text-2xl font-bold" style="color: @statusColor;">@FormatMetricValue(avgData.Average, metricKey)</span>
                        @if (goal.HasValue)
                        {
                            <span class="font-body text-xs" style="color: var(--er-text-dim);">Target: @(isEfficiency ? "≤ " : "")@FormatMetricValue(goal.Value, metricKey)</span>
                        }
                    </div>
                    <div class="font-body text-xs mb-1" style="color: var(--er-text-dim);">@(isEfficiency ? "Focus" : "Low"): @(lowPerformer?.FirstOrDefault() ?? "N/A") (@FormatMetricValue(_lowPerformerValues.GetValueOrDefault(metricKey), metricKey))</div>
                    <div class="font-body text-xs mb-3" style="color: var(--er-text-dim);">Best: @(highPerformer?.FirstOrDefault() ?? "N/A") (@FormatMetricValue(_highPerformerValues.GetValueOrDefault(metricKey), metricKey))</div>

                    @if (goal.HasValue && goal.Value > 0)
                    {
                        double progress;
                        if (isEfficiency)
                        {
                            progress = avgData.Average > 0 ? (goal.Value / avgData.Average) * 100.0 : 0;
                        }
                        else
                        {
                            progress = (avgData.Average / goal.Value) * 100.0;
                        }
                        progress = Math.Clamp(progress, 0, 100);
                        string barClass = progress >= 100 ? "" : progress >= 75 ? "bar-green" : progress >= 50 ? "bar-orange" : "bar-red";
                        <div class="elden-progress elden-progress-shimmer mb-1">
                            <div class="elden-progress-bar @barClass" style="width: @(progress.ToString("F0", CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <div class="font-mono text-xs text-right" style="color: var(--er-text-dim);">@progress.ToString("F0")%</div>
                    }
                </div>
            }
        </div>

        <!-- Team Member Cards (Carousel) -->
        <div class="text-center mb-6">
            <h2 class="font-heading text-2xl" style="color: var(--er-gold);">Champions</h2>
            <div class="elden-divider-ornate mx-auto mt-2" style="max-width: 200px;"></div>
        </div>
        <div class="champion-carousel" id="champion-carousel">
            <div class="carousel-track">
                @foreach (var member in _teamMembers.OrderByDescending(m => GetWeightedScore(m)))
                {
                    var weightedScore = GetWeightedScore(member);
                    bool isKpiWinner = _kpiWinnerByMember.TryGetValue(member.Name, out var wonKpi);

                    <div @key="member.Id"
                         class="elden-character-card @(isKpiWinner ? "elden-border-gold" : "")"
                         style="width: 210px; min-width: 210px; height: 320px;"
                         @onclick="() => NavigateToMember(member.Id)">
                        <div class="card-bg-avatar">
                            <img src="@(AvatarResolver.Resolve(member.Name, member.AvatarUrl))" alt="" class="w-full h-full object-cover" />
                        </div>
                        <div class="card-content">
                            <div class="mt-2">
                                <h3 class="card-name">
                                    @member.Name
                                    @if (isKpiWinner)
                                    {
                                        <span class="gold-brilliance" title="@TeamMember.GetMetricDisplayName(wonKpi!) Leader">&#x2726;</span>
                                    }
                                </h3>
                                @if (isKpiWinner)
                                {
                                    <p class="card-title mt-1">
                                        <span class="gold-badge">&#x2726; @TeamMember.GetMetricDisplayName(wonKpi!) Leader</span>
                                    </p>
                                }
                                else
                                {
                                    var strongestKpi = GetStrongestWeightedArea(member);
                                    if (strongestKpi != null)
                                    {
                                        <p class="card-title mt-1" style="color: var(--er-text-dim);">Best: @TeamMember.GetMetricDisplayName(strongestKpi)</p>
                                    }
                                }
                            </div>

                            <div class="card-score">
                                <div class="card-score-label">Weighted Score</div>
                                <div class="card-score-value" style="color: @(weightedScore >= 70 ? "var(--er-gold-bright)" : weightedScore >= 50 ? "var(--er-green-bright)" : weightedScore >= 30 ? "var(--er-orange-bright)" : "var(--er-red-bright)");">
                                    @weightedScore.ToString("F1")
                                </div>
                                <div class="card-score-label">of 125</div>
                            </div>

                            <div>
                                <div class="flex justify-between items-center text-xs mb-1 px-1">
                                    @{
                                        int level = member.CurrentLevel;
                                        double xpInLevel = member.ExperienceTowardsNextLevel;
                                        double progressPercent = member.ProgressToNextLevelPercentage;
                                    }
                                    <span class="font-heading font-bold" style="color: var(--er-purple);">Lv.@level</span>
                                    <span class="font-mono" style="color: var(--er-text-dim);">@xpInLevel.ToString("F0")/@TeamMember.XpPerLevel.ToString("F0")</span>
                                </div>
                                <div class="elden-xp-bar mx-1">
                                    <div class="elden-xp-fill" style="width: @progressPercent.ToString("F1", CultureInfo.InvariantCulture)%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="carousel-slider-wrap">
                <input type="range" id="champion-slider" class="carousel-slider" min="0" max="1000" value="0" />
            </div>
        </div>

        @if (_podLeaderboard != null && _podLeaderboard.Any())
        {
            <footer class="mt-12 elden-dashboard-section">
                <div class="elden-dashboard-section-header">
                    <div>
                        <div class="elden-dashboard-eyebrow">Pod Atlas</div>
                        <h2 class="elden-dashboard-section-title">Switch Teams</h2>
                        <p class="elden-dashboard-section-copy">The council footer keeps every pod close at hand without crowding the overview itself.</p>
                    </div>
                    <div class="font-body text-sm" style="color: var(--er-text-dim);">@_podLeaderboard.Count teams</div>
                </div>
                <div class="pod-atlas-grid">
                    @foreach (var pod in _podLeaderboard)
                    {
                        bool isCurrent = pod.Name.Equals(PodName, StringComparison.OrdinalIgnoreCase);
                        string rankColor = pod.Rank == 1 ? "var(--er-gold-bright)" : pod.Rank == 2 ? "#c0c0c0" : pod.Rank == 3 ? "var(--er-bronze)" : "var(--er-text-dim)";

                        <button @onclick="() => SwitchToPod(pod.Name)"
                                class="pod-atlas-button @(isCurrent ? "is-current" : "")">
                            <span class="pod-atlas-rank" style="color: @rankColor;">#@pod.Rank</span>
                            <span class="pod-atlas-name">@pod.Name</span>
                            <span class="pod-atlas-score">@pod.Score.ToString("F1")</span>
                        </button>
                    }
                </div>
            </footer>
        }
    }
</div>

@code {
    [Parameter] public string PodName { get; set; } = string.Empty;
    private string _currentPodName = string.Empty;
    private bool _isLoading = true;
    private List<TeamMember> _allMembersCache = new();
    private List<TeamMember> _teamMembers = new();
    private string? _latestPeriod;

    private bool _isSaving;
    private string? _backupMessage;
    private bool _backupSuccess;
    private bool _showHistory;
    private int? _expandedSnapshotId;
    private List<GameScoreboard.Models.PodSnapshot> _snapshots = new();

    private Dictionary<string, (double Average, double Min, double Max)> _departmentAverages = new();
    private Dictionary<string, List<string>> _highPerformerNames = new();
    private Dictionary<string, List<string>> _lowPerformerNames = new();
    private Dictionary<string, double> _highPerformerValues = new();
    private Dictionary<string, double> _lowPerformerValues = new();
    private List<RankedMember>? _podLeaderboard;
    private Dictionary<string, string> _kpiWinnerByMetric = new();
    private Dictionary<string, string> _kpiWinnerByMember = new();

    // Pod-specific KPI keys in display order (used for fallback/default)
    private static readonly List<string> _podMetricKeys = PodMetricCatalog.AllMetrics.ToList();

    // Weighted scoring
    private static readonly Dictionary<string, int> _metricWeights = PodMetricCatalog.MetricWeights.ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);
    private const int TotalWeight = 37;

    // Targets from the Excel sheet
    private static readonly Dictionary<string, double> _metricTargets = PodMetricCatalog.MetricTargets.ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);

    private static readonly HashSet<string> _regularDepartments = new(StringComparer.OrdinalIgnoreCase)
    {
        "front", "computers", "warehouse"
    };

    private static bool IsPodDepartment(string dept) => PodMetricCatalog.IsPodDepartment(dept);

    // Get metrics applicable to a department (HT/Retail = HTBasket/ServAttach, PC = PCBasket/Office)
    private static List<string> GetMetricsForDepartment(string department)
    {
        return PodMetricCatalog.GetApplicableMetrics(department).ToList();
    }

    private static List<string> GetOverviewMetrics(string department) =>
        PodMetricCatalog.GetApplicableMetrics(department).ToList();

    private static bool IsLowerBetter(string metricKey) => PodMetricCatalog.IsLowerBetter(metricKey);

    private bool _carouselInitialized;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnMetricsUpdatedAsync += HandleMetricsUpdated;
        _currentPodName = PodName;
        Console.WriteLine($"[PodOverview] OnInitializedAsync for pod: {PodName}");
        await LoadPodData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && _teamMembers.Any() && !_carouselInitialized)
        {
            _carouselInitialized = true;
            Console.WriteLine($"[PodOverview] Initializing carousel with {_teamMembers.Count} members...");
            await Task.Delay(250);
            try
            {
                await JSRuntime.InvokeVoidAsync("eldenCarousel.init", "champion-carousel", "champion-slider");
                Console.WriteLine("[PodOverview] Carousel JS init call succeeded.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PodOverview] Carousel init FAILED: {ex.Message}");
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(_currentPodName, PodName, StringComparison.OrdinalIgnoreCase) && !string.IsNullOrEmpty(PodName))
        {
            Console.WriteLine($"[PodOverview] Pod changed: {_currentPodName} → {PodName}");
            _currentPodName = PodName;
            await LoadPodDataFromCache();
        }
    }

    private async Task HandleMetricsUpdated()
    {
        Console.WriteLine("[PodOverview] Metrics updated notification received, reloading...");
        await InvokeAsync(async () =>
        {
            _isLoading = true;
            StateHasChanged();
            try
            {
                _allMembersCache.Clear();
                await LoadPodData();
            }
            finally { StateHasChanged(); }
        });
    }

    private async Task LoadPodData()
    {
        _isLoading = true;
        ResetState();
        StateHasChanged();

        if (string.IsNullOrEmpty(PodName)) { _isLoading = false; return; }

        try
        {
            Console.WriteLine($"[PodOverview] Loading data for pod: {PodName} (using AppState cache)");
            _allMembersCache = (await AppState.GetOrFetchMembersAsync(DataService))?.ToList() ?? new List<TeamMember>();
            Console.WriteLine($"[PodOverview] Fetched {_allMembersCache.Count} total members");
            PopulateFromCache();
            await LoadSnapshots();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PodOverview] LoadPodData FAILED: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPodDataFromCache()
    {
        _isLoading = true;
        ResetState();
        StateHasChanged();

        if (string.IsNullOrEmpty(PodName)) { _isLoading = false; return; }

        if (!_allMembersCache.Any())
        {
            Console.WriteLine($"[PodOverview] Cache empty, fetching for pod switch to: {PodName}");
            _allMembersCache = (await AppState.GetOrFetchMembersAsync(DataService))?.ToList() ?? new List<TeamMember>();
        }
        else
        {
            Console.WriteLine($"[PodOverview] Using cached data ({_allMembersCache.Count} members) for pod: {PodName}");
        }

        PopulateFromCache();
        await LoadSnapshots();
        _isLoading = false;
        StateHasChanged();
    }

    private void ResetState()
    {
        _latestPeriod = null;
        _departmentAverages.Clear();
        _highPerformerNames.Clear();
        _lowPerformerNames.Clear();
        _highPerformerValues.Clear();
        _lowPerformerValues.Clear();
        _teamMembers.Clear();
        _carouselInitialized = false;
    }

    private void PopulateFromCache()
    {
        // Build the set of all known pod/department names so we can exclude
        // any member whose Name was accidentally stored as a pod label.
        var allDeptNames = _allMembersCache
            .Select(m => m.Department.Trim().ToLowerInvariant())
            .ToHashSet();

        var teamMembersInDepartment = _allMembersCache
            .Where(m => m.Department.Equals(PodName, StringComparison.OrdinalIgnoreCase)
                        && !allDeptNames.Contains(m.Name.Trim().ToLowerInvariant()))
            .GroupBy(m => m.Name.Trim().ToLowerInvariant())
            .Select(g => g.OrderByDescending(m => m.Id).First())
            .ToList();

        Console.WriteLine($"[PodOverview] Found {teamMembersInDepartment.Count} members for pod '{PodName}'");

        if (teamMembersInDepartment.Any())
        {
            _latestPeriod = PodLeaderboardCalculator.DetermineLatestPeriod(teamMembersInDepartment);

            _teamMembers = string.IsNullOrEmpty(_latestPeriod)
                ? teamMembersInDepartment
                : teamMembersInDepartment
                    .Where(m => m.MetricRecords?.Any(r => r.Period == _latestPeriod) == true)
                    .ToList();

            Console.WriteLine($"[PodOverview] Latest period: {_latestPeriod ?? "none"}, members with metrics: {_teamMembers.Count(m => m.MetricRecords?.Any() == true)}");

            if (!string.IsNullOrEmpty(_latestPeriod))
            {
                CalculateSummary();
            }
        }

        var podsWithData = _allMembersCache
            .Where(m => IsPodDepartment(m.Department) && m.MetricRecords?.Any() == true)
            .GroupBy(m => m.Department, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Any(member => member.MetricRecords?.Any() == true))
            .Select(g => g.Key)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _podLeaderboard = PodLeaderboardCalculator.CalculatePodLeaderboard(
            _allMembersCache.Where(m => podsWithData.Contains(m.Department)),
            _latestPeriod);
    }

    private void CalculateSummary()
    {
        if (_teamMembers == null || !_teamMembers.Any() || string.IsNullOrEmpty(_latestPeriod)) return;

        _departmentAverages.Clear();
        _highPerformerNames.Clear();
        _lowPerformerNames.Clear();
        _highPerformerValues.Clear();
        _lowPerformerValues.Clear();

        foreach (var key in GetOverviewMetrics(PodName))
        {
            var valuesForMetric = _teamMembers
                .Select(m => (Name: m.Name, Value: GetMemberMetricValue(m, key)))
                .Where(pair => pair.Value.HasValue)
                .Select(pair => (pair.Name, Value: pair.Value!.Value))
                .ToList();

            // For AppEff/PMEff, filter out sentinel values >= $20,000
            if (key == "AppEff" || key == "PMEff")
            {
                valuesForMetric = valuesForMetric.Where(v => v.Value < 20000).ToList();
            }

            // For Surveys, 0 means no surveys received - exclude from averages
            if (key == "Surveys")
            {
                valuesForMetric = valuesForMetric.Where(v => v.Value > 0).ToList();
            }

            if (valuesForMetric.Any())
            {
                double avg = valuesForMetric.Average(v => v.Value);
                double minVal = valuesForMetric.Min(v => v.Value);
                double maxVal = valuesForMetric.Max(v => v.Value);
                _departmentAverages[key] = (avg, minVal, maxVal);

                var bestPerformers = valuesForMetric.Where(v => v.Value == maxVal).Select(v => v.Name).ToList();
                var worstPerformers = valuesForMetric.Where(v => v.Value == minVal).Select(v => v.Name).ToList();

                // For AppEff and PMEff, lower is actually better (more efficient spending per app/PM)
                if (key == "AppEff" || key == "PMEff")
                {
                    _highPerformerNames[key] = worstPerformers; // Lower = better efficiency
                    _lowPerformerNames[key] = bestPerformers;
                    _highPerformerValues[key] = minVal;
                    _lowPerformerValues[key] = maxVal;
                }
                else
                {
                    _highPerformerNames[key] = bestPerformers;
                    _lowPerformerNames[key] = worstPerformers;
                    _highPerformerValues[key] = maxVal;
                    _lowPerformerValues[key] = minVal;
                }
            }
        }

        AssignSuperlatives();
    }

    private void AssignSuperlatives()
    {
        _kpiWinnerByMetric.Clear();
        _kpiWinnerByMember.Clear();
        var assigned = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        var sortedKpis = GetOverviewMetrics(PodName)
            .OrderByDescending(k => PodMetricCatalog.GetWeight(k))
            .ThenBy(k => k);

        foreach (var kpi in sortedKpis)
        {
            if (!_highPerformerNames.TryGetValue(kpi, out var candidates) || candidates == null) continue;

            var winner = candidates
                .Where(c => !assigned.Contains(c))
                .OrderByDescending(c => { var m = _teamMembers.FirstOrDefault(m => m.Name == c); return m != null ? GetWeightedScore(m) : 0; })
                .FirstOrDefault();

            if (winner != null)
            {
                _kpiWinnerByMetric[kpi] = winner;
                _kpiWinnerByMember[winner] = kpi;
                assigned.Add(winner);
            }
        }
    }

    private double? GetMemberMetricValue(TeamMember member, string metricKey)
    {
        return PodLeaderboardCalculator.GetMetricValue(member, metricKey, _latestPeriod);
    }

    private double GetWeightedScore(TeamMember member)
    {
        return PodLeaderboardCalculator.GetWeightedScore(member, _latestPeriod);
    }

    private string? GetStrongestWeightedArea(TeamMember member)
    {
        string? bestKey = null;
        double bestScore = double.MinValue;

        foreach (var metricKey in GetOverviewMetrics(member.Department))
        {
            double? rawValue = GetMemberMetricValue(member, metricKey);
            if (!rawValue.HasValue) continue;
            if ((metricKey == "AppEff" || metricKey == "PMEff") && rawValue.Value >= 20000) continue;

            double normalizedScore;
            if (metricKey == "Surveys" && rawValue.Value == 0)
            {
                normalizedScore = 0;
            }
            else
            {
                double target = PodMetricCatalog.GetTarget(metricKey);
                if (IsLowerBetter(metricKey))
                    normalizedScore = target > 0 && rawValue.Value > 0 ? (target / rawValue.Value) * 100.0 : 0;
                else
                    normalizedScore = target > 0 ? (rawValue.Value / target) * 100.0 : 0;
            }

            if (normalizedScore > bestScore)
            {
                bestScore = normalizedScore;
                bestKey = metricKey;
            }
        }

        return bestKey;
    }

    private double? GetMetricGoal(string metricKey)
    {
        return _metricTargets.TryGetValue(metricKey, out var target) ? target : null;
    }

    private int GetMetricWeight(string metricKey)
    {
        return _metricWeights.GetValueOrDefault(metricKey, 0);
    }

    private string GetAverageStatusColor(double average, double? goal, bool lowerIsBetter = false)
    {
        if (!goal.HasValue || goal.Value <= 0) return "var(--er-text)";

        double progress;
        if (lowerIsBetter)
        {
            progress = average > 0 ? (goal.Value / average) * 100.0 : 0;
        }
        else
        {
            progress = (average / goal.Value) * 100.0;
        }

        if (progress >= 100) return "var(--er-gold-bright)";
        if (progress >= 75) return "var(--er-green-bright)";
        if (progress >= 50) return "var(--er-orange-bright)";
        return "var(--er-red-bright)";
    }

    private string FormatPeriodDisplay(string? period)
    {
        if (string.IsNullOrEmpty(period)) return "No Data Available";
        if (DateTime.TryParseExact(period, "yyyy-MM-dd", CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var dt))
            return dt.ToString("MMMM d, yyyy");
        return period;
    }

    private string FormatMetricValue(double value, string metricKey)
    {
        return PodMetricCatalog.FormatMetricValue(value, metricKey);
    }

    private async Task LoadSnapshots()
    {
        try
        {
            _snapshots = await DataService.GetPodSnapshotsAsync(PodName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading snapshots: {ex.Message}");
            _snapshots = new();
        }
    }

    private async Task BackupToDatabase()
    {
        if (_isSaving || _teamMembers == null || !_teamMembers.Any()) return;

        _isSaving = true;
        _backupMessage = null;
        StateHasChanged();

        try
        {
            var snapshotData = _teamMembers.Select(m => new
            {
                m.Name,
                m.Id,
                WeightedScore = GetWeightedScore(m).ToString("F1", CultureInfo.InvariantCulture),
                Metrics = GetOverviewMetrics(PodName).ToDictionary(
                    key => key,
                    key =>
                    {
                        var val = GetMemberMetricValue(m, key);
                        return val.HasValue ? FormatMetricValue(val.Value, key) : "—";
                    })
            }).ToList();

            var json = JsonSerializer.Serialize(snapshotData);

            var snapshot = new GameScoreboard.Models.PodSnapshot
            {
                PodName = PodName,
                Label = _latestPeriod ?? "Manual Backup",
                JsonData = json
            };

            await DataService.SavePodSnapshotAsync(snapshot);
            await LoadSnapshots();

            _backupSuccess = true;
            _backupMessage = $"Snapshot saved at {DateTime.Now:MMM dd, yyyy h:mm tt} with {_teamMembers.Count} members.";
        }
        catch (Exception ex)
        {
            _backupSuccess = false;
            _backupMessage = $"Backup failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void ToggleHistory()
    {
        _showHistory = !_showHistory;
    }

    private void ToggleSnapshotDetail(int snapshotId)
    {
        _expandedSnapshotId = _expandedSnapshotId == snapshotId ? null : snapshotId;
