@* TODO T03: This page is a placeholder with no actual functionality.
   Needs implementation to display historical metric data older than 2 weeks.
   Should include filtering by department and period. *@
@page "/archived-trackers"
@namespace GameScoreboard.Pages
@inject NavigationManager NavigationManager

<div class="min-h-screen p-6 md:p-8" style="background-color: var(--er-bg-primary); color: var(--er-text);">
    <button @onclick="NavigateBack" class="elden-btn mb-6">&larr; Back to Weekly Tracker</button>

    <div class="text-center mb-8">
        <h1 class="title-glow text-3xl">Archived Metrics</h1>
        <div class="elden-divider-ornate mx-auto mt-4" style="max-width: 250px;"></div>
    </div>

    <div class="elden-panel max-w-4xl mx-auto">
        <h2 class="font-heading text-xl mb-4" style="color: var(--er-gold);">Archived Data</h2>

        <p class="font-body mb-4" style="color: var(--er-text-dim);">
            This page will display historical metric data that is older than two weeks.
            Functionality to filter by department and period will be added here.
        </p>

        <div class="p-8 text-center" style="border: 1px dashed var(--er-border); color: var(--er-text-muted);">
            Archived Data Grid/View Will Go Here
        </div>
    </div>
</div>

@code {
    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/weeklytracker");
    }
} 