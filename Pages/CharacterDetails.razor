@* BUG B05 FIX: Removed duplicate method that was incorrectly placed before @page directive *@
@page "/character/{Id:int}"
@namespace GameScoreboard.Pages
@using GameScoreboard.Models
@using GameScoreboard.Services
@using GameScoreboard.Services.Tracking
@using GameScoreboard.Data
@using System.Text
@using Microsoft.AspNetCore.Components.Web
@inject IDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@* BUG B04: GetDoubleValue(), FormatMetricValue(), GetMetricGoal() are duplicated 
   across CharacterDetails, DepartmentOverview, and WeeklyTracker.
   TODO: Extract to a shared utility class in Services/ *@

<div class="min-h-screen px-4 py-8 character-details-root" style="background-color: var(--er-bg-primary); color: var(--er-text); position: relative;">
    @if (_questCopied)
    {
        <div class="quest-copy-toast" role="status">Copied!</div>
    }
    @if (_revealActive)
    {
        <div class="champion-reveal-overlay" aria-busy="true" aria-label="Loading champion">
            <div class="champion-reveal-burst"></div>
            <div class="champion-reveal-card">
                <div class="champion-reveal-rune elden-loading-rune"></div>
                <p class="champion-reveal-kicker">Champion Ledger</p>
                <p class="champion-reveal-title">Sealing the wax…</p>
            </div>
        </div>
    }
    <div class="container mx-auto max-w-6xl" aria-hidden="@_revealActive">
        @if (!_revealActive && _teamMember == null)
        {
            <div class="flex flex-col items-center justify-center mt-20">
                <p class="font-heading text-sm" style="color: var(--er-gold-dim);">Champion not found or could not be loaded.</p>
            </div>
        }
        @if (!_revealActive && _teamMember != null)
        {
            <button @onclick="NavigateBack" class="elden-btn mb-6">
                &larr; @(IsPodMember() ? "Back to Team" : "Back to Champions")
            </button>

            <div @ref="detailsContainer" id="character-details-container"
                 class="elden-card elden-card-ornate overflow-hidden relative" style="border-color: var(--er-border-gold);">
                <div class="absolute top-0 right-0 w-1/2 h-full opacity-10 z-0">
                    @if (!string.IsNullOrEmpty(_teamMember.AvatarUrl))
                    {
                        <img src="@_teamMember.AvatarUrl" alt="" class="w-full h-full object-cover" />
                    }
                </div>

                <div class="elden-corners-inner p-6 flex flex-col md:flex-row relative z-10">
                    <!-- Metrics Section - Left -->
                    <div class="md:w-3/5 pr-8">
                        <div class="flex items-center mb-6">
                            <div class="mr-4">
                                <div class="rounded-full overflow-hidden w-16 h-16" style="border: 2px solid var(--er-gold-dim); background: var(--er-bg-card);">
                                    @if (!string.IsNullOrEmpty(_teamMember.AvatarUrl))
                                    {
                                        <img src="@_teamMember.AvatarUrl" alt="@_teamMember.Name" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center font-heading text-2xl font-bold" style="color: var(--er-gold-dim);">
                                            @_teamMember.Name[0]
                                        </div>
                                    }
                                </div>
                            </div>
                            <div>
                                <h1 class="font-heading text-3xl" style="color: var(--er-text);">@_teamMember.Name</h1>
                                <p class="font-body text-lg italic" style="color: var(--er-gold-dim);">@_teamMember.GetChampionTitle(_allTeamMembers)</p>
                            </div>
                        </div>

                        <h2 class="font-heading text-xl mb-4 pb-2" style="color: var(--er-gold); border-bottom: 1px solid var(--er-gold-dark);">
                            Performance Metrics <span class="font-mono text-sm" style="color: var(--er-text-dim);">(@_latestPeriod)</span>
                        </h2>

                        <div class="space-y-4">
                            @foreach (var metric in GetVisibleMetrics().OrderBy(m => TeamMember.GetMetricDisplayName(m.Key)))
                            {
                                var numericValue = GetMetricDoubleValue(metric.Key);

                                @if (numericValue.HasValue)
                                {
                                    <div class="elden-panel elden-panel-gold" style="border-left-color: @GetMetricBorderColor(metric.Key, numericValue);">
                                        <div class="flex justify-between items-center mb-2">
                                            <div>
                                                <div class="font-heading text-sm tracking-wide" style="color: var(--er-text);">
                                                    @TeamMember.GetMetricDisplayName(metric.Key)
                                                    @if (IsTopPerformer(metric.Key))
                                                    {
                                                        <span class="gold-brilliance" title="Top performer">&#x2726;</span>
                                                    }
                                                </div>
                                                <div class="font-body text-xs" style="color: var(--er-text-dim);">
                                                    Team Avg: @FormatMetricValue(metric.Key, GetTeamAverage(metric.Key))
                                                    @if (IsMetricOffTrack(metric.Key, numericValue))
                                                    {
                                                        <span class="ml-1 font-bold" style="color: var(--er-orange, #c47830);" title="Off track from target">&#x26A0;</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="font-mono text-lg font-bold" style="color: @GetMetricValueColor(metric.Key, numericValue);">
                                                @FormatMetricValue(metric.Key, numericValue)
                                            </div>
                                        </div>

                                        <div class="mt-2 elden-progress relative" style="height: 10px;">
                                            <div class="elden-progress-bar @GetMetricBarCssClass(metric.Key, numericValue)"
                                                 style="width: @GetMetricBarWidth(metric.Key, numericValue)"></div>
                                            <div class="absolute top-0 bottom-0 w-0.5 opacity-70"
                                                 style="left: @GetAverageMarkerPosition(metric.Key); background: var(--er-text);"></div>
                                        </div>

                                        <div class="mt-1 flex justify-between font-mono text-xs" style="color: var(--er-text-dim);">
                                            @if (IsLowerBetterMetric(metric.Key))
                                            {
                                                <span>Best: @FormatMetricValue(metric.Key, GetMetricMinValue(metric.Key))</span>
                                                <span>Score: @GetPerformanceScore(metric.Key, numericValue).ToString("F0")</span>
                                                <span>Focus: @FormatMetricValue(metric.Key, GetMetricMaxValue(metric.Key))</span>
                                            }
                                            else
                                            {
                                                <span>Min: @FormatMetricValue(metric.Key, GetMetricMinValue(metric.Key))</span>
                                                <span>Score: @GetPerformanceScore(metric.Key, numericValue).ToString("F0")</span>
                                                <span>Max: @{ var displayMax = GetDisplayMaxValue(metric.Key); } @FormatMetricValue(metric.Key, displayMax)</span>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    if (metric.Key.Equals("MVP", StringComparison.OrdinalIgnoreCase) && metric.Value != null)
                                    {
                                        <div class="elden-panel elden-panel-gold">
                                            <div class="flex justify-between items-center">
                                                <span class="font-heading text-sm" style="color: var(--er-text);">@TeamMember.GetMetricDisplayName(metric.Key)</span>
                                                <span class="font-mono text-lg font-bold" style="color: var(--er-gold);">@FormatMetricValue(metric.Key, metric.Value)</span>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <!-- Right Sidebar: Quest → Radar → Champion Stats -->
                    <div class="md:w-2/5 mt-8 md:mt-0 md:pl-6">

                        @if (_todayShiftGoals != null)
                        {
                            <div class="mb-4 elden-panel quest-panel-clickable" style="border-color: @(_todayShiftGoals.AnyBuffed ? "var(--er-red)" : "var(--er-border-gold)");"
                                 role="button"
                                 tabindex="0"
                                 @onclick="CopyTodayQuestToClipboard"
                                 @onkeydown="OnQuestPanelKeydown">
                                <h3 class="font-heading text-lg mb-1" style="color: var(--er-gold);">Today's Quest (8-Hour Shift)</h3>
                                @if (_todayShiftGoals.AnyBuffed)
                                {
                                    <p class="font-body text-xs mb-3" style="color: var(--er-text-dim);">Off-track rows show today&apos;s target; red tags show your current performance.</p>
                                }
                                else
                                {
                                    <p class="font-body text-xs mb-3" style="color: var(--er-green-bright);">On track! Keep it up.</p>
                                }
                                <div class="space-y-1 font-mono text-sm">
                                    <div class="@(_todayShiftGoals.RphBuffed ? "quest-metric-buffed" : "quest-metric-on-track")">
                                        @if (_todayShiftGoals.RphBuffed) { <span class="quest-exclamation">!</span> }
                                        RPH Goal: @_todayShiftGoals.RphGoal.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                                        @if (_todayShiftGoals.RphBuffed) { <span style="color: var(--er-red-bright);">@GetQuestOffTrackWithCurrent("RPH")</span> }
                                    </div>
                                    @if (_todayShiftGoals.AppGoal.HasValue)
                                    {
                                        <div class="@(_todayShiftGoals.AppBuffed ? "quest-metric-buffed" : "quest-metric-on-track")">
                                            @if (_todayShiftGoals.AppBuffed) { <span class="quest-exclamation">!</span> }
                                            App Goal: @_todayShiftGoals.AppGoal.Value.ToString("N0") apps
                                            @if (_todayShiftGoals.AppBuffed) { <span style="color: var(--er-red-bright);">@GetQuestOffTrackWithCurrent("AppEff")</span> }
                                        </div>
                                    }
                                    @if (_todayShiftGoals.PmGoal.HasValue)
                                    {
                                        <div class="@(_todayShiftGoals.PmBuffed ? "quest-metric-buffed" : "quest-metric-on-track")">
                                            @if (_todayShiftGoals.PmBuffed) { <span class="quest-exclamation">!</span> }
                                            PM Goal: @_todayShiftGoals.PmGoal.Value.ToString("N0") PMs
                                            @if (_todayShiftGoals.PmBuffed) { <span style="color: var(--er-red-bright);">@GetQuestOffTrackWithCurrent("PMEff")</span> }
                                        </div>
                                    }
                                    @if (_todayShiftGoals.WarrantyAttachGoalPercent.HasValue)
                                    {
                                        <div class="@(_todayShiftGoals.WarrantyBuffed ? "quest-metric-buffed" : "quest-metric-on-track")">
                                            @if (_todayShiftGoals.WarrantyBuffed) { <span class="quest-exclamation">!</span> }
                                            Warranty Attach: @_todayShiftGoals.WarrantyAttachGoalPercent.Value.ToString("F1")%
                                            @if (_todayShiftGoals.WarrantyBuffed) { <span style="color: var(--er-red-bright);">@GetQuestOffTrackWithCurrent("WarrantyAttach")</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (IsPodMember())
                        {
                            <div class="mb-4 elden-panel" style="border-color: var(--er-border-gold);">
                                <h3 class="font-heading text-lg mb-1" style="color: var(--er-gold);">Today's Quest (8-Hour Shift)</h3>
                                <p class="font-body text-xs" style="color: var(--er-text-muted);">Not enough goal data yet to calculate today's targets.</p>
                            </div>
                        }

                        <!-- Radar Chart -->
                        <div class="mb-4 flex justify-center items-center elden-panel" style="min-height: 320px; border-color: var(--er-border-gold);">
                            @if (_radarChartData != null && _latestMetricsDict.Count(kvp => kvp.Value is double || (kvp.Value is string s && double.TryParse(s, out _))) > 2)
                            {
                                var labels = (List<string>?)_radarChartData.GetType().GetProperty("labels")?.GetValue(_radarChartData);
                                var datasets = (List<object>?)_radarChartData.GetType().GetProperty("datasets")?.GetValue(_radarChartData);
                                var data = (datasets?.FirstOrDefault()?.GetType().GetProperty("data")?.GetValue(datasets.First()) as IEnumerable<double>)?.ToList();

                                <RadarChart
                                    Labels="labels"
                                    NormalizedData="data"
                                    Width="320px"
                                    Height="320px" />
                            }
                            else
                            {
                                <p class="font-body text-center" style="color: var(--er-text-muted);">Not enough data for Radar Chart.</p>
                            }
                        </div>

                        <!-- Champion Stats -->
                        <div class="elden-panel" style="border-color: var(--er-border-gold);">
                            <h3 class="font-heading text-lg mb-4" style="color: var(--er-gold);">Champion Stats</h3>
                            <div class="elden-divider mb-4"></div>
                            <div class="space-y-3 font-body text-sm">
                                <div class="flex justify-between">
                                    <span style="color: var(--er-text-dim);">Overall Rank:</span>
                                    <span class="font-heading font-bold" style="color: var(--er-text);">#@GetOverallRank() of @_allTeamMembers.Count(m => m.Department == _teamMember.Department)</span>
                                </div>
                                <div class="flex justify-between">
                                    <span style="color: var(--er-text-dim);">Strongest Area:</span>
                                    @{
                                        var strongest = _teamMember.GetStrongestMetricRelativeToTeam(_teamAverages);
                                        var strongestDisplayName = string.IsNullOrEmpty(strongest) ? "N/A" : TeamMember.GetMetricDisplayName(strongest);
                                    }
                                    <span class="font-bold" style="color: var(--er-gold-bright);">@strongestDisplayName</span>
                                </div>
                                <div class="flex justify-between">
                                    <span style="color: var(--er-text-dim);">Top Categories:</span>
                                    <span class="font-bold" style="color: var(--er-text);">@GetTopCategories()</span>
                                </div>
                                <div class="flex justify-between">
                                    <span style="color: var(--er-text-dim);">Needs Improvement:</span>
                                    <span class="font-bold" style="color: var(--er-red-bright);">@GetImprovedCategories()</span>
                                </div>
                                <div class="flex justify-between">
                                    <span style="color: var(--er-text-dim);">Performance Score:</span>
                                    <span class="font-mono font-bold" style="color: var(--er-gold);">@GetTotalPerformanceScore().ToString("F0") / 125</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    
    private TeamMember? _teamMember; 
    private List<TeamMember> _allTeamMembers = new List<TeamMember>();
    private Dictionary<string, double> _teamAverages = new Dictionary<string, double>();
    private ElementReference detailsContainer;
    
    // New fields for period-specific data
    private string? _latestPeriod = null;
    private List<MetricRecord> _latestMetricRecords = new List<MetricRecord>();
    private Dictionary<string, object?> _latestMetricsDict = new Dictionary<string, object?>();
    
    // Stores all records for the latest period for the current member's department
    private List<MetricRecord> _allLatestPeriodDeptRecords = new(); 
    
    // Field to hold the generated data for the radar chart
    private object? _radarChartData = null;

    private bool _revealActive = true;
    private bool _scrollAfterReveal;
    private bool _questCopied;

    private const int MinChampionRevealMs = 1800;

    protected override async Task OnInitializedAsync()
    {
        var loadStart = DateTime.UtcNow;
        try
        {
            await LoadChampionDataCoreAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"CharacterDetails load: {ex.Message}");
            _teamMember = null;
        }

        if (_teamMember == null)
        {
            _revealActive = false;
        }
        else
        {
            var elapsed = (DateTime.UtcNow - loadStart).TotalMilliseconds;
            if (elapsed < MinChampionRevealMs)
                await Task.Delay((int)(MinChampionRevealMs - elapsed));
            _revealActive = false;
            _scrollAfterReveal = true;
        }
    }

    private async Task LoadChampionDataCoreAsync()
    {
        // 1. Fetch the basic team member info (includes TotalExperience)
        _teamMember = await DataService.GetTeamMemberByIdAsync(Id);

        if (_teamMember == null) return;

        _teamMember.AvatarUrl = AvatarResolver.Resolve(_teamMember.Name, _teamMember.AvatarUrl);

        // 2. Fetch all metric records for this member across all periods
        var allMemberRecords = await DataService.GetMetricRecordsAsync(memberId: Id);

        // 3. Determine the latest period
        _latestPeriod = GetLatestPeriod(allMemberRecords.Select(r => r.Period).Distinct());

        if (_latestPeriod != null)
        {
            _latestMetricRecords = allMemberRecords.Where(r => r.Period == _latestPeriod).ToList();
            _latestMetricsDict = CreateMetricsDictionary(_latestMetricRecords);
            _radarChartData = GenerateRadarChartData();
        }
        else
        {
            _latestMetricRecords.Clear();
            _latestMetricsDict.Clear();
            _radarChartData = null;
        }

        _allTeamMembers = await DataService.GetTeamMembersAsync();
        await CalculateTeamAveragesForLatestPeriod();
        ComputeTodayShiftGoals();
    }

    // --- Helper methods for Period and Metric Dictionary --- 

    private string? GetLatestPeriod(IEnumerable<string?> periodStrings)
    {
        // Simple implementation: assumes "EOM-MMM yyyy" or "Mid-MMM yyyy"
        // Parses the end date and returns the period string corresponding to the max end date.
        return periodStrings
            .Where(p => !string.IsNullOrEmpty(p))
            .Select(p => new { Period = p, EndDate = GetPeriodEndDate(p!) })
            .OrderByDescending(x => x.EndDate)
            .FirstOrDefault()?.Period;
    }

    private DateTime GetPeriodEndDate(string period)
    {
        try
        {
            if (DateTime.TryParseExact(period, "yyyy-MM-dd",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var isoDate))
                return isoDate;

            string[] parts = period.Split('-');
            if (parts.Length < 2) return DateTime.MinValue;
            string monthYear = parts[1]; 
            DateTime monthStartDate = DateTime.ParseExact("01-" + monthYear, "dd-MMM yyyy", System.Globalization.CultureInfo.InvariantCulture);
            
            if (parts[0].Equals("Mid", StringComparison.OrdinalIgnoreCase))
            {
                return monthStartDate.AddDays(14);
            }
            else
            {
                return monthStartDate.AddMonths(1).AddDays(-1);
            }
        }
        catch 
        { 
            Console.WriteLine($"Warning: Could not parse period end date for '{period}'");
            return DateTime.MinValue;
        }
    }
    
    private Dictionary<string, object?> CreateMetricsDictionary(List<MetricRecord> records)
    {
        var metricsDict = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        foreach (var record in records)
        {
            object? displayValue = record.Value; // Default to string
            if (record.Value != null)
            { 
                // Use the robust GetDoubleValue helper to handle various formats ($, %, etc.)
                var parsedDouble = GetDoubleValue(record.Value); 
                if (parsedDouble.HasValue)
                {
                    displayValue = parsedDouble.Value; // Store as double if parse succeeds
                }
                // If GetDoubleValue returns null, we keep the original string value
            }
            metricsDict[record.MetricKey] = displayValue; 
        }
        return metricsDict;
    }

    private IEnumerable<KeyValuePair<string, object?>> GetVisibleMetrics()
    {
        if (!IsPodMember())
        {
            return _latestMetricsDict;
        }

        return PodMetricCatalog.GetApplicableMetrics(_teamMember?.Department)
            .Where(key => _latestMetricsDict.ContainsKey(key))
            .Select(key => new KeyValuePair<string, object?>(key, _latestMetricsDict[key]));
    }
    
    // --- Modified Average Calculation ---
    
    // Calculates averages using only data from the determined _latestPeriod
    private async Task CalculateTeamAveragesForLatestPeriod()
    {
        if (!_allTeamMembers.Any() || _teamMember == null || _latestPeriod == null) 
        {
            _teamAverages = new Dictionary<string, double>();
            return;
        }

        _teamAverages = new Dictionary<string, double>();
        var relevantMembers = _allTeamMembers.Where(m => m.Department == _teamMember.Department).ToList();
        var memberIds = relevantMembers.Select(m => m.Id).ToList();

        // Fetch all relevant records for the latest period for all members in the department
        // Use Task.WhenAll for potentially better performance
        var fetchTasks = memberIds.Select(id => DataService.GetMetricRecordsAsync(memberId: id, period: _latestPeriod)).ToList();
        var results = await Task.WhenAll(fetchTasks);
        var allLatestPeriodRecords = results.SelectMany(list => list).ToList(); // Flatten the results

        // Store fetched records for use in Min/Max calculations later
        _allLatestPeriodDeptRecords = allLatestPeriodRecords; 

        // Get unique metric keys present in this period for this department
        var metricKeysInPeriod = allLatestPeriodRecords.Select(r => r.MetricKey).Distinct(StringComparer.OrdinalIgnoreCase);

        foreach (var key in metricKeysInPeriod)
        {
            var values = allLatestPeriodRecords
                .Where(r => r.MetricKey.Equals(key, StringComparison.OrdinalIgnoreCase) && r.Value != null)
                .Select(r => GetDoubleValue(r.Value))
                .Where(v => v.HasValue)                
                .Select(v => v!.Value)                 
                .ToList();

            // For efficiency metrics, exclude sentinel values (>= $20,000)
            if (IsPodEfficiency(key))
                values = values.Where(v => v < 20000).ToList();

            // For Surveys/5Star, exclude 0 (no surveys received)
            if (key.Equals("Surveys", StringComparison.OrdinalIgnoreCase) || key.Equals("5Star", StringComparison.OrdinalIgnoreCase))
                values = values.Where(v => v > 0).ToList();

            if (values.Any())
            {
                _teamAverages[key] = values.Average();
            }
        }
    }

    // TODO: Update UI loop and helper methods (IsBestInMetric, IsWorstInMetric, GetMetricDoubleValue etc.)
    // to use _latestMetricsDict or _latestMetricRecords instead of _teamMember.MetricRecords

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollAfterReveal && _teamMember != null)
        {
            _scrollAfterReveal = false;
            try
            {
                await Task.Delay(200);
                await JSRuntime.InvokeVoidAsync("scrollToCenter", detailsContainer);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error scrolling: {ex.Message}");
            }
        }
    }
    
    // private void CalculateTeamAverages() // Original method removed/replaced
    // { ... } 
    
    private void NavigateBack()
    {
        if (IsPodMember())
            NavigationManager.NavigateTo($"/pods/{_teamMember!.Department}");
        else
            NavigationManager.NavigateTo($"/departments/{_teamMember?.Department?.ToLower() ?? "computers"}");
    }
    
    // --- TODO: Update Helper methods to use period-specific data --- 

    // Example: Update GetMetricDoubleValue to potentially read from _latestMetricsDict first
     private double? GetMetricDoubleValue(string key)
     {
         foreach (var lookupKey in PodMetricCatalog.GetLookupKeys(key, _teamMember?.Department))
         {
             if (_latestMetricsDict.TryGetValue(lookupKey, out var objValue) && objValue is double dVal)
             {
                 return dVal;
             }

             if (_latestMetricsDict.TryGetValue(lookupKey, out objValue) && objValue is string sVal && double.TryParse(sVal, out dVal))
             {
                 return dVal;
             }
         }

         return null; 
     }

    private static bool IsPodEfficiency(string metricKey) =>
        metricKey.Equals("AppEff", StringComparison.OrdinalIgnoreCase) ||
        metricKey.Equals("PMEff", StringComparison.OrdinalIgnoreCase);

    private static bool IsLowerBetterMetric(string metricKey) =>
        metricKey.Equals("Awk", StringComparison.OrdinalIgnoreCase) || IsPodEfficiency(metricKey);

    private bool IsTopPerformer(string metricKey)
    {
        double? memberValue = GetMetricDoubleValue(metricKey);
        if (!memberValue.HasValue) return false;

        var scores = _allLatestPeriodDeptRecords
                     .Where(r => r.MetricKey.Equals(metricKey, StringComparison.OrdinalIgnoreCase))
                     .Select(r => GetDoubleValue(r.Value))
                     .Where(v => v.HasValue)
                     .Select(v => v!.Value);

        if (IsPodEfficiency(metricKey))
            scores = scores.Where(v => v < 20000);

        var scoreList = scores.ToList();
        if (!scoreList.Any()) return false;

        if (IsLowerBetterMetric(metricKey))
            return memberValue.Value <= scoreList.Min();
        else
            return memberValue.Value >= scoreList.Max();
    }
    
    private bool IsBottomPerformer(string metricKey)
    {
        double? memberValue = GetMetricDoubleValue(metricKey);
        if (!memberValue.HasValue) return false;
        
        var scores = _allLatestPeriodDeptRecords
                     .Where(r => r.MetricKey.Equals(metricKey, StringComparison.OrdinalIgnoreCase))
                     .Select(r => GetDoubleValue(r.Value))
                     .Where(v => v.HasValue)
                     .Select(v => v!.Value);

        if (IsPodEfficiency(metricKey))
            scores = scores.Where(v => v < 20000);

        var scoreList = scores.ToList();
        if (!scoreList.Any()) return false;

        if (IsLowerBetterMetric(metricKey))
            return memberValue.Value >= scoreList.Max();
        else
            return memberValue.Value <= scoreList.Min();
    }
    
    private double GetTeamAverage(string metricKey)
    {
        // Correctly return the pre-calculated average from the dictionary
        return _teamAverages.TryGetValue(metricKey, out var avg) ? avg : 0.0; 
    }
    
    // Other helpers like GetMetricBarClass, GetMetricValueClass, GetMetricBarWidth,
    // GetAverageMarkerPosition, GetMetricMinValue, GetMetricMaxValue, 
    // GetOverallRank, GetTopCategories, GetImprovedCategories, GetTotalPerformanceScore
    // will need to be reviewed and potentially updated to use _latestMetricRecords 
    // or the calculated _teamAverages based on the latest period.
    // For example, GetOverallRank might still use TotalExperience from _teamMember.
    // GetMetricMinValue/MaxValue should calculate based on the fetched allLatestPeriodRecords.

    // GetPerformanceScore helper probably remains okay as it takes currentValue as input.
    
    // Formatting helpers (FormatMetricValue, GetFormattedMetricName) are likely fine.

    private bool IsAboveAverage(string metricKey, double? numericValue)
    {
        if (!numericValue.HasValue) return false;
        double teamAverage = GetTeamAverage(metricKey);
        if (teamAverage <= 0) return false;

        if (IsLowerBetterMetric(metricKey))
            return numericValue.Value < teamAverage;
        else
            return numericValue.Value > teamAverage;
    }

    private bool IsMetricOffTrack(string metricKey, object? value)
    {
        double? numericValue = GetDoubleValue(value);
        if (!numericValue.HasValue) return false;
        if (IsTopPerformer(metricKey)) return false;
        return !IsAboveAverage(metricKey, numericValue) && !IsAtOrAboveGoal(metricKey, numericValue);
    }

