    private void ComputeTodayShiftGoals()
    {
        if (!IsPodMember()) { _todayShiftGoals = null; return; }

        var buffedRph = GetBuffedRphGoal();
        if (!buffedRph.HasValue) { _todayShiftGoals = null; return; }

        double baseRph = buffedRph.Value;
        double baseRevenue = baseRph * 8.0;

        double? appEffGoal = GetMemberGoal("AppEff");
        double? pmEffGoal = GetMemberGoal("PMEff");
        double? warrantyGoal = GetMemberGoal("WarrantyAttach");

        double? baseApps = (appEffGoal.HasValue && appEffGoal.Value > 0)
            ? baseRevenue / appEffGoal.Value : null;
        double? basePms = (pmEffGoal.HasValue && pmEffGoal.Value > 0)
            ? baseRevenue / pmEffGoal.Value : null;

        double rphScore = GetPerformanceScore("RPH", _latestMetricsDict.TryGetValue("RPH", out var rphVal) ? rphVal : null);
        double appScore = GetPerformanceScore("AppEff", _latestMetricsDict.TryGetValue("AppEff", out var appVal) ? appVal : null);
        double pmScore = GetPerformanceScore("PMEff", _latestMetricsDict.TryGetValue("PMEff", out var pmVal) ? pmVal : null);
        double warrantyScore = GetPerformanceScore("WarrantyAttach", _latestMetricsDict.TryGetValue("WarrantyAttach", out var warVal) ? warVal : null);

        // Multiplier: 1.0 when on-track (score >= 100), up to maxMult when behind.
        static double MultFromScore(double score, double maxMult = 2.0)
        {
            if (score >= 100) return 1.0;
            var deficit = Math.Max(0.0, 100.0 - score);
            return Math.Min(1.0 + deficit / 100.0, maxMult);
        }

        double rphMult = MultFromScore(rphScore);
        double appMult = MultFromScore(appScore);
        double pmMult = MultFromScore(pmScore);
        double warrantyMult = MultFromScore(warrantyScore, 1.25);

        double todayRevenue = baseRevenue * rphMult;
        double todayRph = todayRevenue / 8.0;
        double? todayApps = baseApps.HasValue ? Math.Max(1, Math.Round(baseApps.Value * appMult)) : null;
        double? todayPms = basePms.HasValue ? Math.Max(1, Math.Round(basePms.Value * pmMult)) : null;
        double? todayWarranty = warrantyGoal.HasValue
            ? Math.Min(warrantyGoal.Value * warrantyMult, Math.Max(warrantyGoal.Value + 15.0, warrantyGoal.Value))
            : (double?)null;

        // Track which metrics are buffed and by how much
        bool rphBuf = rphMult > 1.01;
        bool appBuf = appMult > 1.01;
        bool pmBuf = pmMult > 1.01;
        bool warBuf = warrantyMult > 1.01;

        _todayShiftGoals = new DailyShiftGoals(
            todayRph, rphBuf, (int)Math.Round((rphMult - 1.0) * 100),
            todayApps, appBuf, (int)Math.Round((appMult - 1.0) * 100),
            todayPms, pmBuf, (int)Math.Round((pmMult - 1.0) * 100),
            todayWarranty, warBuf, (int)Math.Round((warrantyMult - 1.0) * 100));
    }

    private bool IsPodMember() =>
        _teamMember != null && !_regularDepartments.Contains(_teamMember.Department);

    // =========================================================================
    // METRIC TIER CLASSIFICATION
    // =========================================================================
    // Four tiers determine progress-bar color, border, and value text:
    //   Gold  — #1 in the department for this metric (elite)
    //   Green — above team average OR meeting/exceeding goal (solid)
    //   Dim   — below average and below goal (needs work)
    //   Red   — worst in the department (struggling)
    // =========================================================================

    /// <summary>
    /// Checks whether the member's value meets or exceeds the goal for this
    /// metric, respecting lower-is-better inversion for efficiency metrics.
    /// </summary>
    private bool IsAtOrAboveGoal(string metricKey, double? numericValue)
    {
        if (!numericValue.HasValue) return false;
        double? goal = GetMemberGoal(metricKey);
        if (!goal.HasValue || goal.Value <= 0) return false;

        if (IsLowerBetterMetric(metricKey))
            return numericValue.Value <= goal.Value;
        return numericValue.Value >= goal.Value;
    }

    private string GetMetricBorderColor(string metricKey, object? value)
    {
        if (IsTopPerformer(metricKey)) return "var(--er-gold)";
        if (IsBottomPerformer(metricKey)) return "var(--er-red)";
        double? numericValue = GetDoubleValue(value);
        if (IsAboveAverage(metricKey, numericValue) || IsAtOrAboveGoal(metricKey, numericValue))
            return "var(--er-green)";
        return "var(--er-orange)";
    }

    private string GetMetricValueColor(string metricKey, object? value)
    {
        if (IsTopPerformer(metricKey)) return "var(--er-gold-bright)";
        if (IsBottomPerformer(metricKey)) return "var(--er-red-bright)";
        double? numericValue = GetDoubleValue(value);
        if (IsAboveAverage(metricKey, numericValue) || IsAtOrAboveGoal(metricKey, numericValue))
            return "var(--er-green-bright)";
        return "var(--er-orange-bright)";
    }

    private string GetMetricBarCssClass(string metricKey, object? value)
    {
        if (IsTopPerformer(metricKey)) return "";                 // gold gradient (default)
        if (IsBottomPerformer(metricKey)) return "bar-red";
        double? numericValue = GetDoubleValue(value);
        if (IsAboveAverage(metricKey, numericValue)) return "bar-green";
        if (IsAtOrAboveGoal(metricKey, numericValue)) return "bar-green";
        return "bar-orange";
    }

    private object GenerateRadarChartData()
    {
        if (_latestMetricsDict == null || !_latestMetricsDict.Any())
        { 
            return new { labels = new List<string>(), datasets = new List<object>() };
        }

        var labels = new List<string>();
        var normalizedData = new List<double>();

        bool isPod = IsPodMember();
        var radarMetrics = isPod
            ? PodMetricCatalog.GetApplicableMetrics(_teamMember?.Department).ToList()
            : new List<string> { "Revenue", "ASP", "Basket", "M365Attach", "PMAttach", "GSP" };

        foreach (var key in radarMetrics)
        {
            if (_latestMetricsDict.TryGetValue(key, out var rawValueObj))
            {
                double? rawValue = GetDoubleValue(rawValueObj);
                double normalizedScore = 0;

                if (isPod)
                {
                    bool isEfficiency = key == "AppEff" || key == "PMEff";

                    // Sentinel values for efficiency (no apps/PMs sold)
                    if (isEfficiency && rawValue.HasValue && rawValue.Value >= 20000)
                    {
                        normalizedScore = 0;
                    }
                    else if (key == "Surveys" && rawValue.HasValue && rawValue.Value == 0)
                    {
                        normalizedScore = 0;
                    }
                    else if (rawValue.HasValue && _podMetricTargets.TryGetValue(key, out var target) && target > 0)
                    {
                        if (isEfficiency)
                            normalizedScore = rawValue.Value > 0 ? Math.Min((target / rawValue.Value) * 100.0, 100.0) : 0;
                        else
                            normalizedScore = Math.Min((rawValue.Value / target) * 100.0, 100.0);
                    }
                }
                else
                {
                    double? goal = GetMetricGoal(key);
                    if (rawValue.HasValue && goal.HasValue && goal.Value > 0)
                        normalizedScore = Math.Min((rawValue.Value / goal.Value) * 100.0, 100.0);
                    else if (rawValue.HasValue && rawValue.Value > 0)
                        normalizedScore = 50.0;
                }

                labels.Add(TeamMember.GetMetricDisplayName(key)); 
                normalizedData.Add(Math.Clamp(normalizedScore, 0, 100)); 
            }
            else
            {
                labels.Add(TeamMember.GetMetricDisplayName(key));
                normalizedData.Add(0);
            }
        }

        var datasets = new List<object>
        {
            new {
                label = $"{_teamMember?.Name ?? "Member"} Performance (% of Goal)",
                data = normalizedData,
                fill = true,
                backgroundColor = "rgba(255, 215, 0, 0.1)",
                borderColor = "rgb(255, 215, 0)",
                pointBackgroundColor = "rgb(255, 215, 0)",
                pointBorderColor = "#fff",
                pointHoverBackgroundColor = "#fff",
                pointHoverBorderColor = "rgb(255, 215, 0)"
            }
        };

        return new { labels, datasets };
    }
}