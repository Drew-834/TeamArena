    private string GetMetricBarWidth(string metricKey, object? value)
    {
        if (_teamMember == null) return "0%";
        if (value == null) return "0%";
        double? numericValue = GetDoubleValue(value);
        if (!numericValue.HasValue) return "0%";

        double max = GetMetricMaxValue(metricKey);
        double min = GetMetricMinValue(metricKey);
        double range = max - min;
        
        if (range <= 0) return numericValue > 0 ? "100%" : "0%";

        double percentage;
        if (IsLowerBetterMetric(metricKey))
            percentage = Math.Min(Math.Max(((max - numericValue.Value) / range) * 100, 0), 100);
        else
            percentage = Math.Min(Math.Max(((numericValue.Value - min) / range) * 100, 0), 100);

        return $"{percentage:F1}%";
    }
    
    private string GetAverageMarkerPosition(string metricKey)
    {
        double average = GetTeamAverage(metricKey);
        double max = GetMetricMaxValue(metricKey);
        double min = GetMetricMinValue(metricKey);
        double range = max - min;

        if (range <= 0) return "50%";

        double percentage;
        if (IsLowerBetterMetric(metricKey))
            percentage = Math.Min(Math.Max(((max - average) / range) * 100, 0), 100);
        else
            percentage = Math.Min(Math.Max(((average - min) / range) * 100, 0), 100);

        return $"{percentage:F1}%";
    }
    
    private double GetMetricMinValue(string metricKey)
    {
        return _allLatestPeriodDeptRecords
                .Where(r => r.MetricKey.Equals(metricKey, StringComparison.OrdinalIgnoreCase))
                .Select(r => GetDoubleValue(r.Value))
                .Where(v => v.HasValue)
                .Select(v => v!.Value)
                .DefaultIfEmpty(0)
                .Min();
    }
    
    // =========================================================================
    // PERFORMANCE SCORING ENGINE
    // =========================================================================
    // Computes a 0-100 score for a single metric. Uses the member's personal
    // goal (via GetMemberGoal) first, falls back to team average as baseline.
    // Adds a small peer-comparison adjustment (+/-5) so two members at the
    // same goal percentage are differentiated by their team-average position.
    //
    // Special cases:
    //   - Surveys/5Star = 0  -> returns a small penalty (15) instead of 0
    //   - Efficiency sentinel (>=20000) -> returns 0 (no apps/PMs sold)
    //   - Lower-is-better metrics invert the ratio (goal/value)
    // =========================================================================
    private double CalculatePerformanceScore(string metricKey, double numericValue, Dictionary<string, double> teamAverages)
    {
        bool lowerIsBetter = IsLowerBetterMetric(metricKey);

        // Surveys/5Star = 0 means "no data", not "bad performance".
        // Return a small penalty so it still drags the score slightly.
        if ((metricKey.Equals("Surveys", StringComparison.OrdinalIgnoreCase) ||
             metricKey.Equals("5Star", StringComparison.OrdinalIgnoreCase)) && numericValue == 0)
            return 15;

        // Sentinel values for efficiency metrics (>= $20,000 = unreliable data)
        if (IsPodEfficiency(metricKey) && numericValue >= 20000) return 0;

        // Use per-person goals first, then pod defaults, then legacy goals
        double? goal = GetMemberGoal(metricKey);

        double baseScoreTarget;
        if (goal.HasValue && goal.Value > 0)
            baseScoreTarget = goal.Value;
        else if (teamAverages.TryGetValue(metricKey, out double average) && average > 0)
            baseScoreTarget = average;
        else
            return numericValue > 0 ? 50 : 0;

        if (baseScoreTarget <= 0) return 0;

        double score;
        if (lowerIsBetter)
        {
            if (numericValue <= 0) return 100;
            score = (baseScoreTarget / numericValue) * 100.0;
        }
        else
        {
            score = (numericValue / baseScoreTarget) * 100.0;
        }

        // Peer adjustment: nudge score based on team-average comparison.
        if (teamAverages.TryGetValue(metricKey, out double teamAvg) && teamAvg > 0)
        {
            bool aboveAvg = lowerIsBetter
                ? numericValue < teamAvg
                : numericValue > teamAvg;
            score += aboveAvg ? 5.0 : -5.0;
        }

        // Diminishing returns for exceptional performance: logarithmic bonus
        // above 100 rewards excellence without letting specialization dominate.
        if (score > 100)
        {
            double excess = score - 100;
            double bonus = 15.0 * Math.Log(1 + excess / 20.0);
            score = 100 + Math.Min(bonus, 25.0);
        }

        return Math.Clamp(score, 0, 125);
    }
    
    // Overload GetPerformanceScore to fetch the current value
    private double GetPerformanceScore(string metricKey, object? currentValue)
    {
        double? numericValue = GetDoubleValue(currentValue); // Use helper to convert object?
        if (!numericValue.HasValue) return 50; // Default score if not numeric
        
        // Use the existing _teamAverages calculated in OnInitializedAsync
        return CalculatePerformanceScore(metricKey, numericValue.Value, _teamAverages);
    }
    
    // Helper to convert various object types to double?
    // Updated to handle string parsing after removing common symbols
    private double? GetDoubleValue(object? value)
    {
        if (value == null) return null;
        if (value is double d) return d;
        if (value is int i) return (double)i;
        if (value is long l) return (double)l;
        if (value is decimal dec) return (double)dec;
        
        if (value is string sVal)
        {
            return TrackerValueSanitizer.ParseNullableDouble(sVal);
        }
        
        return null; 
    }
    
    /// <summary>
    /// Ranks the current member within their department by weighted performance
    /// score (not XP). Builds each member's metrics dict from the shared
    /// _allLatestPeriodDeptRecords so every member is scored identically.
    /// </summary>
    private int GetOverallRank()
    {
        if (_teamMember == null || !_allTeamMembers.Any()) return 1;

        var deptMembers = _allTeamMembers
            .Where(m => m.Department == _teamMember.Department)
            .ToList();

        double myScore = GetTotalPerformanceScore();
        int rank = 1;

        foreach (var m in deptMembers)
        {
            if (m.Id == _teamMember.Id) continue;
            double mScore = ComputePerformanceScoreForMember(m);
            if (mScore > myScore) rank++;
        }

        return rank;
    }

    /// <summary>
    /// Computes the weighted performance score for any team member using their
    /// records from _allLatestPeriodDeptRecords. This ensures ranking uses the
    /// exact same scoring logic as GetTotalPerformanceScore.
    /// </summary>
    private double ComputePerformanceScoreForMember(TeamMember member)
    {
        var memberRecords = _allLatestPeriodDeptRecords
            .Where(r => r.TeamMemberId == member.Id)
            .ToList();

        if (!memberRecords.Any()) return 0;

        var metricsDict = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        foreach (var record in memberRecords)
        {
            object? val = record.Value;
            if (val != null)
            {
                var parsed = GetDoubleValue(val);
                if (parsed.HasValue) val = parsed.Value;
            }
            metricsDict[record.MetricKey] = val;
        }

        return ComputeWeightedScore(metricsDict);
    }
    
    private string GetTopCategories(int count = 2)
    {
        if (_teamMember == null || !_latestMetricsDict.Any()) return "N/A";

        var topMetrics = GetVisibleMetrics()
            .Where(kvp => kvp.Value is double || (kvp.Value is string s && double.TryParse(s, out _)))
            .Select(kvp => new { Key = kvp.Key, Score = GetPerformanceScore(kvp.Key, kvp.Value) })
            .OrderByDescending(m => m.Score)
            .Take(count)
            .Select(m => TeamMember.GetMetricDisplayName(m.Key).Split(' ')[0])
            .ToList();

        return topMetrics.Any() ? string.Join(", ", topMetrics) : "N/A";
    }
    
    private string GetImprovedCategories(int count = 2)
    {
        if (_teamMember == null || !_latestMetricsDict.Any()) return "N/A";

        var bottomMetrics = GetVisibleMetrics()
           .Where(kvp => kvp.Value is double || (kvp.Value is string s && double.TryParse(s, out _)))
           .Select(kvp => new { Key = kvp.Key, Score = GetPerformanceScore(kvp.Key, kvp.Value) })
           .OrderBy(m => m.Score)
           .Take(count)
           .Select(m => TeamMember.GetMetricDisplayName(m.Key).Split(' ')[0])
           .ToList();

        return bottomMetrics.Any() ? string.Join(", ", bottomMetrics) : "N/A";
    }
    
    // =========================================================================
    // POD METRIC WEIGHTS — provided by management, must sum to 32/32 = 1.0
    // RPH and AppEff are the two heaviest KPIs (21.875% each).
    // 5-Star carries the lightest weight (9.375%).
    // =========================================================================
    private static readonly Dictionary<string, double> _podMetricWeights = new(StringComparer.OrdinalIgnoreCase)
    {
        { "RPH",            7.0 / 32.0 },
        { "AppEff",         7.0 / 32.0 },
        { "PMEff",          5.0 / 32.0 },
        { "WarrantyAttach", 5.0 / 32.0 },
        { "Surveys",        3.0 / 32.0 },
    };

    /// <summary>
    /// Computes the total performance score for the current member.
    /// Pod members use weighted scoring; regular department members use equal weighting.
    /// </summary>
    private double GetTotalPerformanceScore()
    {
        if (_teamMember == null || !_latestMetricsDict.Any())
             return 0;

        return ComputeWeightedScore(_latestMetricsDict);
    }

    /// <summary>
    /// Core weighted-score calculation shared by GetTotalPerformanceScore and
    /// ComputePerformanceScoreForMember (used for ranking).
    /// </summary>
    private double ComputeWeightedScore(Dictionary<string, object?> metricsDict)
    {
        bool isPod = IsPodMember();
        double weightedSum = 0;
        double totalWeight = 0;

        var weightedKeys = isPod
            ? PodMetricCatalog.GetApplicableMetrics(_teamMember?.Department)
            : metricsDict.Keys.ToList();

        foreach (var metricKey in weightedKeys)
        {
            if (!metricsDict.TryGetValue(metricKey, out var value))
                continue;

            double? numVal = GetDoubleValue(value);
            if (!numVal.HasValue) continue;

            double score = CalculatePerformanceScore(metricKey, numVal.Value, _teamAverages);
            double weight = 1.0;

            if (isPod && _podMetricWeights.TryGetValue(metricKey, out var podWeight))
                weight = podWeight;

            weightedSum += score * weight;
            totalWeight += weight;
        }

        if (totalWeight <= 0) return 0;
        return Math.Min(weightedSum / totalWeight, 125);
    }
    
    private string GetFormattedMetricName(string metricKey)
    {
        var displayName = TeamMember.GetMetricDisplayName(metricKey);
        return displayName.Split(' ')[0]; // Return just the first word for brevity
    }
    
    private string FormatMetricValue(string metricKey, object? value)
    {
        if (value == null) return "N/A";
        var valueText = value.ToString() ?? "N/A";

        return metricKey switch
        {
            "M365Attach" or "GSP" or "PMAttach" or "PickRate" or "WarrantyAttach" or "AccAttach" or "ServAttach" or "Office" =>
                value is double dPercent ? $"{dPercent:F1}%" :
                value is int iPercent ? $"{iPercent:F1}%" :
                valueText + "%",
            "Revenue" or "ASP" or "Basket" or "Pick$" or "PCBasket" or "HTBasket" =>
                value is double dCurrency ? $"${dCurrency:N2}" :
                value is int iCurrency ? $"${iCurrency:N0}" :
                "$" + valueText,
            "AppEff" or "PMEff" =>
                value is double dEff ? $"${dEff:N0}" :
                value is int iEff ? $"${iEff:N0}" :
                "$" + valueText,
            "RPH" =>
                value is double dRph ? $"${dRph:N0}" :
                value is int iRph ? $"${iRph:N0}" :
                "$" + valueText,
            "BP" or "PM" or "PickQuantity" =>
                value is int iCount ? iCount.ToString("N0") :
                value is double dCount ? ((int)dCount).ToString("N0") :
                valueText + "#",
            "5Star" or "Surveys" =>
                value is double dRating ? dRating.ToString("F1") :
                valueText,
            "Awk" =>
               value is double dMins ? $"{dMins:F1} min" :
               value is int iMins ? $"{iMins} min" :
               valueText + " min",
            "MVP" => valueText,
            _ => value is double dVal ? dVal.ToString("F1") :
                 value is int iVal ? iVal.ToString() :
                 valueText
        };
    }
    
    // Helper method to determine the Max value to display (Goal or Actual Max)
    private double? GetDisplayMaxValue(string metricKey)
    {
        double? goal = metricKey switch
        {
            "PMAttach" => 25.0,
            "M365Attach" => 30.0,
            "GSP" => 20.0,
            _ => null
        };

        if (_podMetricTargets.TryGetValue(metricKey, out var podGoal))
            goal = podGoal;

        if (goal.HasValue && !IsLowerBetterMetric(metricKey))
            return goal.Value;

        return GetMetricMaxValue(metricKey);
    }
    
    private double GetMetricMaxValue(string metricKey)
    {
        if (_teamMember == null) return 0; // Added null check for _teamMember (Fixes CS8602)
        return _allLatestPeriodDeptRecords
                .Where(r => r.MetricKey.Equals(metricKey, StringComparison.OrdinalIgnoreCase))
                .Select(r => GetDoubleValue(r.Value))
                .Where(v => v.HasValue)
                .Select(v => v!.Value)
                .DefaultIfEmpty(0)
                .Max();
    }

    // Get metric goal (copied from DepartmentOverview/WeeklyTracker)
    private double? GetMetricGoal(string metricKey)
    {
         // Ensure goals are defined for all metrics used in the radar chart
         return metricKey switch
         {
             "PMAttach" => 25.0,    // Example goal
             "M365Attach" => 30.0,  // Example goal
             "GSP" => 20.0,         // Example goal
             "Revenue" => 75000.0,  // Example goal (adjust as needed)
             "ASP" => 650.0,        // Example goal (adjust as needed)
             "Basket" => 150.0,     // Example goal (adjust as needed)
             _ => null // No specific goal defined
         };
    }

    private static readonly HashSet<string> _regularDepartments = new(StringComparer.OrdinalIgnoreCase)
    {
        "front", "computers", "warehouse"
    };

    private static readonly Dictionary<string, double> _podMetricTargets = PodMetricCatalog.MetricTargets.ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);

    private double? GetMemberGoal(string metricKey)
    {
        if (_teamMember != null)
        {
            if (metricKey.Equals("RPH", StringComparison.OrdinalIgnoreCase) && _teamMember.RphGoal.HasValue)
                return _teamMember.RphGoal;
            if (metricKey.Equals("AppEff", StringComparison.OrdinalIgnoreCase) && _teamMember.AppEffGoal.HasValue)
                return _teamMember.AppEffGoal;
            if (metricKey.Equals("PMEff", StringComparison.OrdinalIgnoreCase) && _teamMember.PmEffGoal.HasValue)
                return _teamMember.PmEffGoal;
            if (metricKey.Equals("WarrantyAttach", StringComparison.OrdinalIgnoreCase) && _teamMember.WarrantyAttachGoal.HasValue)
                return _teamMember.WarrantyAttachGoal;
            if (metricKey.Equals("AccAttach", StringComparison.OrdinalIgnoreCase) && _teamMember.AccAttachGoal.HasValue)
                return _teamMember.AccAttachGoal;
        }

        if (IsPodMember() && _podMetricTargets.TryGetValue(metricKey, out var podTarget))
            return podTarget;

        return GetMetricGoal(metricKey);
    }

    private double? GetBuffedRphGoal()
    {
        var baseGoal = GetMemberGoal("RPH");
        if (!baseGoal.HasValue || baseGoal.Value <= 0) return null;
        return baseGoal.Value * 1.2;
    }

    // =========================================================================
    // TODAY'S QUEST — daily shift goal calculation with buff detection.
    // Each metric tracks whether the member is behind pace (buffed = true)
    // and by what percentage their target was raised. Buffed metrics carry
    // a negative connotation: "you're behind and need to push harder."
    // =========================================================================
    private record DailyShiftGoals(
        double RphGoal, bool RphBuffed, int RphBuffPercent,
        double? AppGoal, bool AppBuffed, int AppBuffPercent,
        double? PmGoal, bool PmBuffed, int PmBuffPercent,
        double? WarrantyAttachGoalPercent, bool WarrantyBuffed, int WarrantyBuffPercent)
    {
        public bool AnyBuffed => RphBuffed || AppBuffed || PmBuffed || WarrantyBuffed;
    }

    private DailyShiftGoals? _todayShiftGoals;

    private string GetQuestOffTrackWithCurrent(string metricKey)
    {
        if (!_latestMetricsDict.TryGetValue(metricKey, out var raw) || raw == null)
            return "  Off-track";
        return "  Off-track — " + FormatMetricValue(metricKey, raw);
    }

    private string GetTodayQuestCopyText()
    {
        if (_todayShiftGoals == null) return string.Empty;
        var g = _todayShiftGoals;
        var en = System.Globalization.CultureInfo.GetCultureInfo("en-US");
        var sb = new StringBuilder();
        sb.AppendLine("Today's Quest (8-Hour Shift)");
        if (g.AnyBuffed)
            sb.AppendLine("Off-track rows show today's target; red tags show your current performance.");
        else
            sb.AppendLine("On track! Keep it up.");
        sb.AppendLine();
        sb.Append(g.RphBuffed ? "! " : string.Empty);
        sb.Append("RPH Goal: ");
        sb.Append(g.RphGoal.ToString("C0", en));
        if (g.RphBuffed) sb.Append(GetQuestOffTrackWithCurrent("RPH"));
        sb.AppendLine();
        if (g.AppGoal.HasValue)
        {
            sb.Append(g.AppBuffed ? "! " : string.Empty);
            sb.Append("App Goal: ");
            sb.Append(g.AppGoal.Value.ToString("N0", en));
            sb.Append(" apps");
            if (g.AppBuffed) sb.Append(GetQuestOffTrackWithCurrent("AppEff"));
            sb.AppendLine();
        }
        if (g.PmGoal.HasValue)
        {
            sb.Append(g.PmBuffed ? "! " : string.Empty);
            sb.Append("PM Goal: ");
            sb.Append(g.PmGoal.Value.ToString("N0", en));
            sb.Append(" PMs");
            if (g.PmBuffed) sb.Append(GetQuestOffTrackWithCurrent("PMEff"));
            sb.AppendLine();
        }
        if (g.WarrantyAttachGoalPercent.HasValue)
        {
            sb.Append(g.WarrantyBuffed ? "! " : string.Empty);
            sb.Append("Warranty Attach: ");
            sb.Append(g.WarrantyAttachGoalPercent.Value.ToString("F1", en));
            sb.Append("%");
            if (g.WarrantyBuffed) sb.Append(GetQuestOffTrackWithCurrent("WarrantyAttach"));
        }
        return sb.ToString().TrimEnd();
    }

    private async Task CopyTodayQuestToClipboard()
    {
        if (_todayShiftGoals == null) return;
        var text = GetTodayQuestCopyText();
        if (string.IsNullOrEmpty(text)) return;
        try
        {
            var ok = await JSRuntime.InvokeAsync<bool>("eldenWriteClipboard", text);
            if (ok)
            {
                _questCopied = true;
                StateHasChanged();
                await Task.Delay(1400);
                _questCopied = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Copy quest: {ex.Message}");
        }
    }

