@using System.Globalization

<div class="focus-five-sigil @CssClass @SeverityClass">
    @if (Nodes.Any())
    {
        <svg width="@Width" height="@Height" viewBox="0 0 220 220" class="focus-five-sigil-svg" role="img" aria-label="Focus Five constellation map">
            <defs>
                <filter id="@($"{_chartId}-constellation-glow")">
                    <feGaussianBlur stdDeviation="2.8" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            <circle class="focus-five-constellation-halo" cx="110" cy="110" r="97" />
            <circle class="focus-five-constellation-ring" cx="110" cy="110" r="88" />
            <circle class="focus-five-constellation-ring focus-five-constellation-ring-dashed" cx="110" cy="110" r="70" />

            @foreach (var trail in GetTrails())
            {
                <path d="@trail"
                      class="focus-five-constellation-trail" />
            }

            @foreach (var bridge in GetPodBridges())
            {
                <line x1="@bridge.X1.ToString("F2", CultureInfo.InvariantCulture)"
                      y1="@bridge.Y1.ToString("F2", CultureInfo.InvariantCulture)"
                      x2="@bridge.X2.ToString("F2", CultureInfo.InvariantCulture)"
                      y2="@bridge.Y2.ToString("F2", CultureInfo.InvariantCulture)"
                      class="focus-five-constellation-bridge" />
            }

            <circle class="focus-five-constellation-core" cx="110" cy="110" r="28" />
            <text x="110" y="103" class="focus-five-constellation-center" text-anchor="middle">@CenterLabel</text>
            <text x="110" y="120" class="focus-five-constellation-sub" text-anchor="middle">@SubLabel</text>

            @foreach (var node in Nodes.Select((item, index) => new { Item = item, Index = index }))
            {
                var point = GetPoint(node.Index);
                var radius = GetNodeRadius(node.Item.Importance);
                var podLabel = GetPodLabel(node.Item.Pod);

                <g class="focus-five-constellation-node-group @GetNodeSeverityClass(node.Item.Severity)">
                    <circle class="focus-five-constellation-node-aura"
                            cx="@point.X.ToString("F2", CultureInfo.InvariantCulture)"
                            cy="@point.Y.ToString("F2", CultureInfo.InvariantCulture)"
                            r="@(radius + 5).ToString("F2", CultureInfo.InvariantCulture)"
                            filter="@($"url(#{_chartId}-constellation-glow)")" />
                    <circle class="focus-five-constellation-node"
                            cx="@point.X.ToString("F2", CultureInfo.InvariantCulture)"
                            cy="@point.Y.ToString("F2", CultureInfo.InvariantCulture)"
                            r="@radius.ToString("F2", CultureInfo.InvariantCulture)" />
                    <text x="@GetNameLabelX(node.Index).ToString("F2", CultureInfo.InvariantCulture)"
                          y="@GetNameLabelY(node.Index).ToString("F2", CultureInfo.InvariantCulture)"
                          class="focus-five-constellation-name"
                          text-anchor="@GetTextAnchor(node.Index)">@node.Item.Name</text>
                    <text x="@GetPodLabelX(node.Index).ToString("F2", CultureInfo.InvariantCulture)"
                          y="@GetPodLabelY(node.Index).ToString("F2", CultureInfo.InvariantCulture)"
                          class="focus-five-constellation-pod"
                          text-anchor="@GetTextAnchor(node.Index)">@podLabel</text>
                </g>
            }
        </svg>
    }
</div>

@code {
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string SeverityClass { get; set; } = "";
    [Parameter] public string Width { get; set; } = "220px";
    [Parameter] public string Height { get; set; } = "220px";
    [Parameter] public string CenterLabel { get; set; } = "";
    [Parameter] public string SubLabel { get; set; } = "";
    [Parameter] public List<ConstellationNode> Nodes { get; set; } = new();

    public sealed class ConstellationNode
    {
        public string Name { get; set; } = "";
        public string Pod { get; set; } = "";
        public double Importance { get; set; }
        public double Severity { get; set; }
    }

    private readonly string _chartId = $"focus-five-sigil-{Guid.NewGuid():N}";

    private static readonly (double X, double Y)[] _points =
    {
        (110, 52),
        (156, 84),
        (145, 154),
        (78, 167),
        (54, 103)
    };

    private (double X, double Y) GetPoint(int index)
    {
        return index < _points.Length ? _points[index] : _points[^1];
    }

    private IEnumerable<string> GetTrails()
    {
        if (Nodes.Count < 2)
        {
            yield break;
        }

        for (int i = 0; i < Nodes.Count - 1; i++)
        {
            var start = GetPoint(i);
            var end = GetPoint(i + 1);
            var midX = (start.X + end.X) / 2;
            var midY = ((start.Y + end.Y) / 2) - (i % 2 == 0 ? 10 : -8);
            yield return $"M {start.X.ToString("F2", CultureInfo.InvariantCulture)} {start.Y.ToString("F2", CultureInfo.InvariantCulture)} Q {midX.ToString("F2", CultureInfo.InvariantCulture)} {midY.ToString("F2", CultureInfo.InvariantCulture)} {end.X.ToString("F2", CultureInfo.InvariantCulture)} {end.Y.ToString("F2", CultureInfo.InvariantCulture)}";
        }
    }

    private IEnumerable<(double X1, double Y1, double X2, double Y2)> GetPodBridges()
    {
        for (int i = 1; i < Nodes.Count; i++)
        {
            if (!string.Equals(Nodes[i].Pod, Nodes[0].Pod, StringComparison.OrdinalIgnoreCase))
            {
                var start = GetPoint(0);
                var end = GetPoint(i);
                yield return (start.X, start.Y, end.X, end.Y);
            }
        }
    }

    private double GetNodeRadius(double importance)
    {
        return 4.5 + (Math.Clamp(importance, 0, 100) / 100.0) * 8.5;
    }

    private string GetNodeSeverityClass(double severity)
    {
        if (severity >= 85)
        {
            return "is-critical";
        }

        if (severity >= 55)
        {
            return "is-warning";
        }

        return "is-watch";
    }

    private double GetNameLabelX(int index)
    {
        var point = GetPoint(index);
        return point.X + (index <= 1 ? 12 : index == 2 ? 10 : -12);
    }

    private double GetNameLabelY(int index)
    {
        var point = GetPoint(index);
        return point.Y + (index == 0 ? -12 : index >= 3 ? 16 : -10);
    }

    private double GetPodLabelX(int index)
    {
        return GetNameLabelX(index);
    }

    private double GetPodLabelY(int index)
    {
        return GetNameLabelY(index) + 12;
    }

    private string GetTextAnchor(int index)
    {
        return index >= 3 ? "end" : "start";
    }

    private static string GetPodLabel(string pod)
    {
        if (string.IsNullOrWhiteSpace(pod))
        {
            return "";
        }

        return pod.Length <= 14 ? pod : pod[..13] + "…";
    }
}
