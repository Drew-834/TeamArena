@using System.Globalization

<div class="focus-five-starfield @CssClass">
    @if (Territories.Any())
    {
        <svg viewBox="0 0 1200 760" class="focus-five-starfield-svg" role="img" aria-label="Focus Five constellation pressure map">
            <defs>
                <radialGradient id="@($"{_chartId}-center-glow")" cx="50%" cy="50%" r="65%">
                    <stop offset="0%" stop-color="rgba(231, 206, 136, 0.26)" />
                    <stop offset="65%" stop-color="rgba(231, 206, 136, 0.08)" />
                    <stop offset="100%" stop-color="rgba(231, 206, 136, 0)" />
                </radialGradient>
                <filter id="@($"{_chartId}-node-glow")">
                    <feGaussianBlur stdDeviation="4.4" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            <rect x="0" y="0" width="1200" height="760" class="focus-five-starfield-backdrop" />

            @foreach (var bridge in GetRegionBridges())
            {
                <path d="@bridge"
                      class="focus-five-starfield-bridge" />
            }

            <circle cx="600" cy="380" r="154" class="focus-five-starfield-center-halo" fill="@($"url(#{_chartId}-center-glow)")" />
            <circle cx="600" cy="380" r="112" class="focus-five-starfield-center-ring" />
            <circle cx="600" cy="380" r="52" class="focus-five-starfield-center-core" />
            <text x="600" y="374" class="focus-five-starfield-center-title" text-anchor="middle">@CenterLabel</text>
            <text x="600" y="408" class="focus-five-starfield-center-sub" text-anchor="middle">@SubLabel</text>

            @foreach (var territory in Territories.Select((item, index) => new { Item = item, Index = index }))
            {
                var anchor = GetRegionAnchor(territory.Index, Territories.Count);
                var rotation = GetRegionRotation(territory.Index);

                <g class="focus-five-starfield-region @GetTerritorySeverityClass(territory.Item.Severity)">
                    <ellipse cx="@Fmt(anchor.X)"
                             cy="@Fmt(anchor.Y)"
                             rx="150"
                             ry="102"
                             transform="rotate(@Fmt(rotation) @Fmt(anchor.X) @Fmt(anchor.Y))"
                             class="focus-five-starfield-territory-aura" />
                    <ellipse cx="@Fmt(anchor.X)"
                             cy="@Fmt(anchor.Y)"
                             rx="122"
                             ry="80"
                             transform="rotate(@Fmt(rotation) @Fmt(anchor.X) @Fmt(anchor.Y))"
                             class="focus-five-starfield-territory-ring" />
                    <circle cx="@Fmt(anchor.X)"
                            cy="@Fmt(anchor.Y)"
                            r="15"
                            class="focus-five-starfield-territory-core" />
                    <text x="@Fmt(anchor.X)"
                          y="@Fmt(anchor.Y - 114)"
                          class="focus-five-starfield-territory-label"
                          text-anchor="middle">@territory.Item.Label</text>
                    @foreach (var node in territory.Item.Nodes.Select((item, index) => new { Item = item, Index = index }))
                    {
                        var point = GetNodePoint(anchor, node.Index, territory.Index, territory.Item.Nodes.Count);
                        var radius = GetNodeRadius(node.Item.Importance);

                        <line x1="@Fmt(anchor.X)"
                              y1="@Fmt(anchor.Y)"
                              x2="@Fmt(point.X)"
                              y2="@Fmt(point.Y)"
                              class="focus-five-starfield-spoke" />
                        <g class="focus-five-starfield-node-group @GetNodeSeverityClass(node.Item.Severity)">
                            <circle class="focus-five-starfield-node-aura"
                                    cx="@Fmt(point.X)"
                                    cy="@Fmt(point.Y)"
                                    r="@Fmt(radius + 7)"
                                    filter="@($"url(#{_chartId}-node-glow)")" />
                            <circle class="focus-five-starfield-node"
                                    cx="@Fmt(point.X)"
                                    cy="@Fmt(point.Y)"
                                    r="@Fmt(radius)" />
                            <text x="@Fmt(GetNameLabelX(point, anchor))"
                                  y="@Fmt(GetNameLabelY(point))"
                                  class="focus-five-starfield-node-name"
                                  text-anchor="@GetTextAnchor(point, anchor)">@node.Item.Name</text>
                            <text x="@Fmt(GetPodLabelX(point, anchor))"
                                  y="@Fmt(GetPodLabelY(point))"
                                  class="focus-five-starfield-node-pod"
                                  text-anchor="@GetTextAnchor(point, anchor)">@GetPodLabel(node.Item.Pod)</text>
                        </g>
                    }
                </g>
            }
        </svg>
    }
</div>

@code {
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string CenterLabel { get; set; } = "";
    [Parameter] public string SubLabel { get; set; } = "";
    [Parameter] public List<KpiTerritory> Territories { get; set; } = new();

    public sealed class KpiTerritory
    {
        public string MetricKey { get; set; } = "";
        public string Label { get; set; } = "";
        public string GoalLabel { get; set; } = "";
        public int Weight { get; set; }
        public double Severity { get; set; }
        public List<ConstellationNode> Nodes { get; set; } = new();
    }

    public sealed class ConstellationNode
    {
        public string Name { get; set; } = "";
        public string Pod { get; set; } = "";
        public double Importance { get; set; }
        public double Severity { get; set; }
    }

    private readonly string _chartId = $"focus-five-starfield-{Guid.NewGuid():N}";

    private static readonly (double X, double Y)[] _presetAnchors =
    {
        (276, 208),
        (928, 214),
        (924, 556),
        (270, 554),
        (600, 144)
    };

    private static readonly (double X, double Y)[] _nodeOffsets =
    {
        (-104, -30),
        (94, -52),
        (124, 24),
        (70, 92),
        (-96, 80)
    };

    private (double X, double Y) GetRegionAnchor(int index, int total)
    {
        if (total <= _presetAnchors.Length && index < _presetAnchors.Length)
        {
            return _presetAnchors[index];
        }

        var angle = (-90 + (360.0 / Math.Max(total, 1)) * index) * Math.PI / 180.0;
        return
        (
            600 + Math.Cos(angle) * 314,
            380 + Math.Sin(angle) * 258
        );
    }

    private IEnumerable<string> GetRegionBridges()
    {
        for (int i = 0; i < Territories.Count; i++)
        {
            var anchor = GetRegionAnchor(i, Territories.Count);
            var controlX = 600 + ((anchor.X - 600) * 0.55);
            var controlY = 380 + ((anchor.Y - 380) * 0.55) + (i % 2 == 0 ? -28 : 28);
            yield return $"M {Fmt(600)} {Fmt(380)} Q {Fmt(controlX)} {Fmt(controlY)} {Fmt(anchor.X)} {Fmt(anchor.Y)}";
        }
    }

    private static double GetRegionRotation(int index)
    {
        return index switch
        {
            0 => -12,
            1 => 10,
            2 => -8,
            3 => 14,
            _ => 0
        };
    }

    private static (double X, double Y) RotatePoint((double X, double Y) point, double angleDegrees)
    {
        var radians = angleDegrees * Math.PI / 180.0;
        var cos = Math.Cos(radians);
        var sin = Math.Sin(radians);
        return
        (
            (point.X * cos) - (point.Y * sin),
            (point.X * sin) + (point.Y * cos)
        );
    }

    private (double X, double Y) GetNodePoint((double X, double Y) anchor, int nodeIndex, int territoryIndex, int nodeCount)
    {
        var baseOffset = _nodeOffsets[Math.Min(nodeIndex, _nodeOffsets.Length - 1)];
        var rotation = GetRegionRotation(territoryIndex) + ((territoryIndex % 2 == 0 ? 1 : -1) * 10);
        var rotated = RotatePoint(baseOffset, rotation);
        var spread = nodeCount switch
        {
            <= 1 => 0.62,
            2 => 0.78,
            3 => 0.88,
            4 => 0.96,
            _ => 1.0
        };

        return (anchor.X + (rotated.X * spread), anchor.Y + (rotated.Y * spread));
    }

    private static double GetNodeRadius(double importance)
    {
        return 5.5 + (Math.Clamp(importance, 0, 100) / 100.0) * 10.5;
    }

    private static string GetNodeSeverityClass(double severity)
    {
        if (severity >= 85)
        {
            return "is-critical";
        }

        if (severity >= 55)
        {
            return "is-warning";
        }

        return "is-watch";
    }

    private static string GetTerritorySeverityClass(double severity)
    {
        if (severity > 40)
        {
            return "is-critical";
        }

        if (severity > 20)
        {
            return "is-warning";
        }

        return "is-watch";
    }

    private static double GetNameLabelX((double X, double Y) point, (double X, double Y) anchor)
    {
        return point.X + (point.X >= anchor.X ? 18 : -18);
    }

    private static double GetNameLabelY((double X, double Y) point)
    {
        return point.Y - 14;
    }

    private static double GetPodLabelX((double X, double Y) point, (double X, double Y) anchor)
    {
        return GetNameLabelX(point, anchor);
    }

    private static double GetPodLabelY((double X, double Y) point)
    {
        return point.Y + 18;
    }

    private static string GetTextAnchor((double X, double Y) point, (double X, double Y) anchor)
    {
        return point.X >= anchor.X ? "start" : "end";
    }

    private static string GetPodLabel(string pod)
    {
        if (string.IsNullOrWhiteSpace(pod))
        {
            return "";
        }

        return pod.Length <= 18 ? pod : pod[..17] + "…";
    }

    private static string Fmt(double value)
    {
        return value.ToString("F2", CultureInfo.InvariantCulture);
    }
}
