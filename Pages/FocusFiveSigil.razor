@using System.Globalization

<div class="focus-five-skill-tree @CssClass @(Slide is null ? "" : GetSlideSeverityClass(Slide.Severity))">
    @if (Slide != null)
    {
        <div class="focus-five-skill-tree-hud">
            <div class="focus-five-skill-tree-overline">KPI Focus @Slide.SlideNumber/@Slide.SlideCount</div>
            <div class="focus-five-skill-tree-header">
                <div>
                    <h3 class="focus-five-skill-tree-title">@Slide.Label</h3>
                    <div class="focus-five-skill-tree-goal">Goal @Slide.GoalLabel</div>
                </div>
                <div class="focus-five-skill-tree-badges">
                    <span class="focus-five-skill-tree-badge">@Slide.SeverityLabel</span>
                    <span class="focus-five-skill-tree-badge">W @Slide.Weight</span>
                </div>
            </div>
        </div>

        <svg viewBox="0 0 1200 760" class="focus-five-skill-tree-svg" role="img" aria-label="@($"{Slide.Label} skill tree")">
            <defs>
                <filter id="@($"{_chartId}-node-glow")">
                    <feGaussianBlur stdDeviation="4.4" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            <g class="focus-five-skill-tree-network">
                @foreach (var branch in GetBranches())
                {
                    <path d="@branch"
                          class="focus-five-skill-tree-branch" />
                }

                <circle cx="@Fmt(_rootPoint.X)"
                        cy="@Fmt(_rootPoint.Y)"
                        r="22"
                        class="focus-five-skill-tree-root-aura" />
                <circle cx="@Fmt(_rootPoint.X)"
                        cy="@Fmt(_rootPoint.Y)"
                        r="10"
                        class="focus-five-skill-tree-root" />

                @foreach (var node in Slide.Nodes.Select((item, index) => new { Item = item, Index = index }))
                {
                    var point = GetPoint(node.Index);
                    var radius = GetNodeRadius(node.Item.Importance);

                    <g class="focus-five-skill-tree-node-group @GetNodeSeverityClass(node.Item.Severity)">
                        <circle class="focus-five-skill-tree-node-aura"
                                cx="@Fmt(point.X)"
                                cy="@Fmt(point.Y)"
                                r="@Fmt(radius + 9)"
                                filter="@($"url(#{_chartId}-node-glow)")" />
                        <circle class="focus-five-skill-tree-node"
                                cx="@Fmt(point.X)"
                                cy="@Fmt(point.Y)"
                                r="@Fmt(radius)" />
                        <text x="@Fmt(GetNameLabelX(point))"
                              y="@Fmt(GetNameLabelY(point))"
                              class="focus-five-skill-tree-node-name"
                              text-anchor="@GetTextAnchor(point)">@node.Item.Name</text>
                        <text x="@Fmt(GetPodLabelX(point))"
                              y="@Fmt(GetPodLabelY(point))"
                              class="focus-five-skill-tree-node-pod"
                              text-anchor="@GetTextAnchor(point)">@GetPodLabel(node.Item.Pod)</text>
                        <text x="@Fmt(GetDeltaLabelX(point))"
                              y="@Fmt(GetDeltaLabelY(point))"
                              class="focus-five-skill-tree-node-delta"
                              text-anchor="@GetTextAnchor(point)">@node.Item.DeltaLabel</text>
                    </g>
                }
            </g>
        </svg>
    }
</div>

@code {
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public KpiSlide? Slide { get; set; }

    public sealed class KpiSlide
    {
        public string MetricKey { get; set; } = "";
        public string Label { get; set; } = "";
        public string GoalLabel { get; set; } = "";
        public int Weight { get; set; }
        public double Severity { get; set; }
        public string SeverityLabel { get; set; } = "";
        public int SlideNumber { get; set; }
        public int SlideCount { get; set; }
        public List<ConstellationNode> Nodes { get; set; } = new();
    }

    public sealed class ConstellationNode
    {
        public string Name { get; set; } = "";
        public string Pod { get; set; } = "";
        public double Importance { get; set; }
        public double Severity { get; set; }
        public string DeltaLabel { get; set; } = "";
        public string ImpactLabel { get; set; } = "";
    }

    private readonly string _chartId = $"focus-five-skill-tree-{Guid.NewGuid():N}";

    private static readonly (double X, double Y) _rootPoint = (600, 612);

    private static readonly (double X, double Y)[] _points =
    {
        (600, 470),
        (390, 372),
        (812, 372),
        (270, 224),
        (930, 216)
    };

    private IEnumerable<string> GetBranches()
    {
        if (Slide == null)
        {
            yield break;
        }

        for (int i = 0; i < Slide.Nodes.Count; i++)
        {
            var point = GetPoint(i);
            var start = GetBranchStart(i);
            var midX = (start.X + point.X) / 2;
            var midY = ((start.Y + point.Y) / 2) - (i == 0 ? 34 : 18);
            yield return $"M {Fmt(start.X)} {Fmt(start.Y)} Q {Fmt(midX)} {Fmt(midY)} {Fmt(point.X)} {Fmt(point.Y)}";
        }
    }

    private static (double X, double Y) GetBranchStart(int nodeIndex)
    {
        return nodeIndex switch
        {
            0 => _rootPoint,
            1 => _points[0],
            2 => _points[0],
            3 => _points[1],
            4 => _points[2],
            _ => _rootPoint
        };
    }

    private static (double X, double Y) GetPoint(int index)
    {
        return _points[Math.Min(index, _points.Length - 1)];
    }

    private static double GetNodeRadius(double importance)
    {
        return 11 + (Math.Clamp(importance, 0, 100) / 100.0) * 18;
    }

    private static string GetNodeSeverityClass(double severity)
    {
        if (severity >= 85)
        {
            return "is-critical";
        }

        if (severity >= 55)
        {
            return "is-warning";
        }

        return "is-watch";
    }

    private static string GetSlideSeverityClass(double severity)
    {
        if (severity > 40)
        {
            return "is-critical";
        }

        if (severity > 20)
        {
            return "is-warning";
        }

        return "is-watch";
    }

    private static double GetNameLabelX((double X, double Y) point)
    {
        return point.X + (point.X >= 600 ? 24 : -24);
    }

    private static double GetNameLabelY((double X, double Y) point)
    {
        return point.Y - 16;
    }

    private static double GetPodLabelX((double X, double Y) point)
    {
        return GetNameLabelX(point);
    }

    private static double GetPodLabelY((double X, double Y) point)
    {
        return point.Y + 20;
    }

    private static double GetDeltaLabelX((double X, double Y) point)
    {
        return GetNameLabelX(point);
    }

    private static double GetDeltaLabelY((double X, double Y) point)
    {
        return point.Y + 40;
    }

    private static string GetTextAnchor((double X, double Y) point)
    {
        return point.X >= 600 ? "start" : "end";
    }

    private static string GetPodLabel(string pod)
    {
        if (string.IsNullOrWhiteSpace(pod))
        {
            return "";
        }

        return pod.Length <= 18 ? pod : pod[..17] + "…";
    }

    private static string Fmt(double value)
    {
        return value.ToString("F2", CultureInfo.InvariantCulture);
    }
}
