<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="min-h-screen flex items-center justify-center px-6">
                <div class="elden-panel elden-panel-gold text-center max-w-2xl w-full animate-fade-in-up">
                    <div class="text-rune text-sm tracking-[0.3em] uppercase mb-3">Lost Grace</div>
                    <h1 class="title-glow text-4xl mb-4">404 - Page Not Found</h1>
                    <p class="font-body text-xl mb-8" style="color: var(--er-text-dim);">Sorry, there is nothing at this address.</p>
                    <a href="/" class="elden-btn elden-btn-primary">
                        Return to Character Select
                    </a>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>