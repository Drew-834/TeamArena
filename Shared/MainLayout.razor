@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JSRuntime
@using GameScoreboard.Services
@inject IDataService DataService
@inject NavigationManager NavigationManager
@inject AppState AppState
@using GameScoreboard.Models
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing

<div class="relative min-h-screen elden-shell" style="background-color: var(--er-bg-primary);">
    <div class="elden-atmosphere"></div>
    <canvas id="elden-particles-canvas"></canvas>
    <div class="elden-vignette @(_isRouteTransitionActive ? "is-active" : "")"></div>

    @if (!_isAuthenticated)
    {
        <div id="password-modal" class="elden-modal-backdrop @(_showPasswordModal ? "" : "hidden")">
            <div class="elden-modal">
                <h2 class="elden-modal-title">Sealed Passage</h2>
                <div class="elden-divider-ornate mb-4"></div>
                <div class="mb-4">
                    <input type="password" @bind="PasswordInputValue" @bind:event="oninput" @onkeydown="HandlePasswordKeydown"
                           class="elden-input w-full"
                           placeholder="Password" />
                </div>
                @if (!string.IsNullOrEmpty(_passwordError))
                {
                    <p class="text-sm mb-4" style="color: var(--er-red-bright);">@_passwordError</p>
                }
                <button @onclick="CheckPassword" class="elden-btn elden-btn-primary w-full text-center">Authenticate</button>
            </div>
        </div>
    }

    @if (_isAuthenticated)
    {
        <header class="elden-shell-header @(_showSearch ? "shell-is-searching" : "")">
            <div class="elden-shell-header-inner">
                <button class="elden-shell-nav-btn" @onclick="NavigateViaShell" title="@_contextNavLabel">
                    @_contextNavLabel
                </button>
                <div class="elden-shell-titleblock">
                    <div class="elden-shell-kicker">Guided By Grace</div>
                    <div class="elden-shell-title">@_currentChamberTitle</div>
                    <div class="elden-shell-subtitle">@_currentRouteDescriptor</div>
                </div>
                <div class="elden-shell-actions">
                    <button class="elden-shell-icon-btn" @onclick="ToggleSearch" title="Search Champions">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </button>
                    <button class="elden-shell-icon-btn" @onclick="ToggleMute" title="@(_isMuted ? "Unmute" : "Mute")">
                        @(_isMuted ? "🔇" : "🔊")
                    </button>
                </div>
            </div>
        </header>
    }

    <main class="relative z-10 @(_showTermsModal || _showPasswordModal ? "filter blur-sm pointer-events-none" : "") transition-all duration-300">
        <div class="elden-route-stage @(_isAuthenticated ? "is-authenticated" : "") @(_isRouteTransitionActive ? "is-transitioning" : "")" @key="_routeKey">
            @Body
        </div>
    </main>

    @if (_isAuthenticated && _showTermsModal)
    {
        <TermsOfUseModal IsVisible="@_showTermsModal" OnAccepted="HandleTermsAccepted" />
    }

    @if (_showSearch)
    {
        <div class="elden-search-backdrop" @onclick="CloseSearch"></div>
        <div class="elden-search-panel">
            <input @ref="_searchInputRef"
                   type="text"
                   class="elden-search-input"
                   placeholder="Search champions..."
                   @bind-value="_searchQuery"
                   @bind-value:event="oninput"
                   @onkeydown="HandleSearchKeydown" />
            @if (_searchResults.Any())
            {
                <ul class="elden-search-results">
                    @foreach (var member in _searchResults.Take(8))
                    {
                        <li class="elden-search-result-item" @onclick="() => NavigateToCharacter(member.Id)">
                            <span class="font-heading text-sm" style="color: var(--er-gold);">@member.Name</span>
                            <span class="font-body text-xs" style="color: var(--er-text-dim);">@member.Department</span>
                        </li>
                    }
                </ul>
            }
            else if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <div class="elden-search-empty">No champions found</div>
            }
        </div>
    }

    <footer class="relative z-10 text-center text-xs p-3 @(_showTermsModal ? "filter blur-sm" : "") transition-all duration-300"
            style="color: var(--er-text-muted);">
        &copy; @DateTime.Now.Year Drew Carrillo. All Rights Reserved.
    </footer>
</div>

@code {
    // Auth state
    private bool _isAuthenticated = false;
    private bool _showPasswordModal = false;
    private string _passwordInput = string.Empty;
    private string _passwordError = string.Empty;
    // Public Sealed Passage gate for index/home routes.
    // IMPORTANT: Keep this as 1411Advisor for general access.
    // Admin tracker pages must use Admin321 with separate session keys.
    private const string PublicGatePassword = "1411Advisor";
    private const string PublicAuthSessionKey = "publicGateAuthenticated";
    private const string PublicAuthTimeSessionKey = "publicGateAuthTime";
    private const long AuthTimeoutMs = 30 * 60 * 1000; // 30 minutes

    // Existing state
    private bool _showTermsModal = false;
    private bool _termsChecked = false;
    private bool _audioInitialized = false;
    private bool _isMuted = false;
    private bool _isRouteTransitionActive = false;
    private string _currentChamberTitle = "Roundtable Hold";
    private string _currentRouteDescriptor = "Character Select";
    private string _contextNavLabel = "Home";
    private string _contextNavTarget = "/";
    private string _routeKey = "route-initial";

    protected override void OnInitialized()
    {
        AppState.StartPreload(DataService);
        UpdateRouteChrome(NavigationManager.Uri);
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private bool _showSearch = false;
    private string _searchQuery = string.Empty;
    private List<TeamMember> _allMembers = new();
    private bool _membersLoaded = false;
    private ElementReference _searchInputRef;

    private string PasswordInputValue
    {
        get => _passwordInput;
        set { _passwordInput = value; if (!string.IsNullOrEmpty(_passwordError)) _passwordError = string.Empty; }
    }

    private List<TeamMember> _searchResults =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? new()
            : _allMembers
                .Where(m => m.Name != null && m.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                .OrderBy(m => m.Name)
                .ToList();

    private async Task ToggleSearch()
    {
        _showSearch = !_showSearch;
        if (_showSearch)
        {
            _searchQuery = string.Empty;
            if (!_membersLoaded)
            {
                try
                {
                    _allMembers = await AppState.GetOrFetchMembersAsync(DataService) ?? new();
                    _membersLoaded = true;
                }
                catch { _allMembers = new(); }
            }
            StateHasChanged();
            await Task.Yield();
            try { await _searchInputRef.FocusAsync(); } catch { }
        }
    }

    private void CloseSearch()
    {
        _showSearch = false;
        _searchQuery = string.Empty;
    }

    private void HandleSearchKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseSearch();
        if (e.Key == "Enter" && _searchResults.Any())
            NavigateToCharacter(_searchResults.First().Id);
    }

    private void NavigateToCharacter(int id)
    {
        _showSearch = false;
        _searchQuery = string.Empty;
        NavigationManager.NavigateTo($"/character/{id}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eldenParticles.init", "elden-particles-canvas");

            // Check auth first
            if (!_isAuthenticated)
            {
                try
                {
                    // Check session timeout for the public/index gate only.
                    var authTime = await JSRuntime.InvokeAsync<string?>("sessionStorage.getItem", PublicAuthTimeSessionKey);
                    if (!string.IsNullOrEmpty(authTime) && long.TryParse(authTime, out long timestamp))
                    {
                        var elapsed = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() - timestamp;
                        if (elapsed > AuthTimeoutMs)
                        {
                            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", PublicAuthSessionKey);
                            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", PublicAuthTimeSessionKey);
                        }
                    }

                    var isAuth = await JSRuntime.InvokeAsync<string?>("sessionStorage.getItem", PublicAuthSessionKey);
                    if (isAuth == "true")
                    {
                        _isAuthenticated = true;
                        _showPasswordModal = false;
                    }
                    else
                    {
                        _showPasswordModal = true;
                    }
                }
                catch
                {
                    _showPasswordModal = true;
                }
                StateHasChanged();
                return;
            }

            // If authenticated but terms not checked, show terms
            if (!_termsChecked)
            {
                _termsChecked = true;
                try
                {
                    var accepted = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "termsAccepted");
                    if (accepted != "true")
                    {
                        _showTermsModal = true;
                        StateHasChanged();
                    }
                    else
                    {
                        await InitAudio();
                    }
                }
                catch
                {
                    _showTermsModal = true;
                    StateHasChanged();
                }
            }
        }
    }

    private async Task InitAudio()
    {
        if (_audioInitialized) return;
        _audioInitialized = true;
        try
        {
            await JSRuntime.InvokeVoidAsync("eldenAudio.init");
            await JSRuntime.InvokeVoidAsync("eldenAudio.startAmbient");
        }
        catch { }
    }

    private async Task HandleTermsAccepted()
    {
        _showTermsModal = false;
        try
        {
            await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "termsAccepted", "true");
            await InitAudio();
        }
        catch { }
        StateHasChanged();
    }

    private async Task CheckPassword()
    {
        if (_passwordInput == PublicGatePassword)
        {
            _passwordError = string.Empty;
            _isAuthenticated = true;
            _showPasswordModal = false;
            _showTermsModal = true; // Show terms after successful auth
            try
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", PublicAuthSessionKey, "true");
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", PublicAuthTimeSessionKey, DateTimeOffset.UtcNow.ToUnixTimeMilliseconds().ToString());
            }
            catch { }
        }
        else
        {
            _passwordError = "Incorrect password.";
            _passwordInput = string.Empty;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandlePasswordKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CheckPassword();
        }
    }

    private async Task ToggleMute()
    {
        try
        {
            _isMuted = await JSRuntime.InvokeAsync<bool>("eldenAudio.toggleMute");
            StateHasChanged();
        }
        catch { }
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateRouteChrome(e.Location);
        _routeKey = $"route-{DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";

        if (_isAuthenticated)
        {
            _isRouteTransitionActive = true;
            await InvokeAsync(StateHasChanged);

            try { await JSRuntime.InvokeVoidAsync("eldenAudio.playTransition"); } catch { }

            await Task.Delay(260);
            _isRouteTransitionActive = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void UpdateRouteChrome(string uri)
    {
        var relative = NavigationManager.ToBaseRelativePath(uri);
        relative = relative.Split('?', '#')[0].Trim('/');

        if (string.IsNullOrWhiteSpace(relative))
        {
            _currentChamberTitle = "Roundtable Hold";
            _currentRouteDescriptor = "Character Select";
            _contextNavLabel = "Home";
            _contextNavTarget = "/";
            return;
        }

        var segments = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var first = segments[0].ToLowerInvariant();

        switch (first)
        {
            case "pods":
                _currentChamberTitle = "War Council";
                _currentRouteDescriptor = segments.Length > 1 ? Uri.UnescapeDataString(segments[^1]).Replace('-', ' ') : "Team Index";
                _contextNavLabel = segments.Length > 1 ? "Back to Teams" : "Back to Home";
                _contextNavTarget = segments.Length > 1 ? "/pods" : "/";
                break;
            case "podtracker":
                _currentChamberTitle = "Leader Dashboard";
                _currentRouteDescriptor = "Tracker Command";
                _contextNavLabel = "Back to Teams";
                _contextNavTarget = "/pods";
                break;
            case "character":
                _currentChamberTitle = "Champion Ledger";
                _currentRouteDescriptor = "Individual Dossier";
                _contextNavLabel = "Back to Home";
                _contextNavTarget = "/";
                break;
            case "departments":
                _currentChamberTitle = "Department Chronicle";
                _currentRouteDescriptor = segments.Length > 1 ? Uri.UnescapeDataString(segments[^1]).Replace('-', ' ') : "Overview";
                _contextNavLabel = "Back to Home";
                _contextNavTarget = "/";
                break;
            case "weeklytracker":
                _currentChamberTitle = "Hidden Archives";
                _currentRouteDescriptor = "Weekly Command";
                _contextNavLabel = "Back to Home";
                _contextNavTarget = "/";
                break;
            case "archivedtrackers":
                _currentChamberTitle = "Archive Vault";
                _currentRouteDescriptor = "Weekly Records";
                _contextNavLabel = "Back to Tracker";
                _contextNavTarget = "/weeklytracker";
                break;
            default:
                _currentChamberTitle = "The Lands Between";
                _currentRouteDescriptor = Uri.UnescapeDataString(relative).Replace('-', ' ');
                _contextNavLabel = "Back to Home";
                _contextNavTarget = "/";
                break;
        }
    }

    private void NavigateViaShell()
    {
        NavigationManager.NavigateTo(_contextNavTarget);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
