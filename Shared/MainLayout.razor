@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime

<div class="relative min-h-screen" style="background-color: var(--er-bg-primary);">
    <div class="elden-atmosphere"></div>
    <canvas id="elden-particles-canvas"></canvas>

    <main class="relative z-10 @(_showTermsModal ? "filter blur-sm pointer-events-none" : "") transition-all duration-300">
        @Body
    </main>

    <TermsOfUseModal IsVisible="@_showTermsModal" OnAccepted="HandleTermsAccepted" />

    <button class="elden-mute-btn" @onclick="ToggleMute" title="@(_isMuted ? "Unmute" : "Mute")">
        @(_isMuted ? "🔇" : "🔊")
    </button>

    <footer class="relative z-10 text-center text-xs p-3 @(_showTermsModal ? "filter blur-sm" : "") transition-all duration-300"
            style="color: var(--er-text-muted);">
        &copy; @DateTime.Now.Year Drew Carrillo. All Rights Reserved.
    </footer>
</div>

@code {
    private bool _showTermsModal = false;
    private bool _termsChecked = false;
    private bool _audioInitialized = false;
    private bool _isMuted = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eldenParticles.init", "elden-particles-canvas");

            if (!_termsChecked)
            {
                _termsChecked = true;
                try
                {
                    var accepted = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "termsAccepted");
                    if (accepted != "true")
                    {
                        _showTermsModal = true;
                        StateHasChanged();
                    }
                    else
                    {
                        await InitAudio();
                    }
                }
                catch
                {
                    _showTermsModal = true;
                    StateHasChanged();
                }
            }
        }
    }

    private async Task InitAudio()
    {
        if (_audioInitialized) return;
        _audioInitialized = true;
        try
        {
            await JSRuntime.InvokeVoidAsync("eldenAudio.init");
            await JSRuntime.InvokeVoidAsync("eldenAudio.startAmbient");
        }
        catch { }
    }

    private async Task HandleTermsAccepted()
    {
        _showTermsModal = false;
        try
        {
            await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "termsAccepted", "true");
            await InitAudio();
        }
        catch { }
        StateHasChanged();
    }

    private async Task ToggleMute()
    {
        try
        {
            _isMuted = await JSRuntime.InvokeAsync<bool>("eldenAudio.toggleMute");
            StateHasChanged();
        }
        catch { }
    }
}
