@using Microsoft.AspNetCore.Components

@if (IsVisible)
{
    <div class="elden-modal-backdrop">
        <div class="elden-modal elden-card-ornate">
            <div class="elden-corners-inner">
                <h2 class="elden-modal-title">Terms of Use & Acceptance</h2>

                <div class="elden-divider-ornate"></div>

                <div class="max-h-60 overflow-y-auto pr-2 mb-6 space-y-3 text-sm" style="color: var(--er-text-dim); font-family: var(--font-body);">
                    <p>Welcome to <span class="text-rune">Team Arena</span>.</p>
                    <p>
                        <strong style="color: var(--er-gold);">Ownership:</strong> This application, including its concept, design, code, and underlying ideas, is the intellectual property of the original creator. All rights reserved.
                    </p>
                    <p>
                        <strong style="color: var(--er-gold);">Usage:</strong> This application is provided for internal team use only. You agree not to copy, modify, distribute, sell, reverse-engineer, or create derivative works without explicit written permission.
                    </p>
                    <p>
                        <strong style="color: var(--er-gold);">Data:</strong> Any data entered should be considered confidential. Ensure you have the necessary permissions to enter and view this data.
                    </p>
                    <p>
                        <strong style="color: var(--er-gold);">Disclaimer:</strong> Provided "as is" without warranty of any kind. Use at your own risk.
                    </p>
                    <p>
                        <strong style="color: var(--er-gold);">Acceptance:</strong> By clicking below, you acknowledge that you have read, understood, and agree to these terms.
                    </p>
                </div>

                <button @onclick="AcceptTerms" class="elden-btn elden-btn-primary w-full text-center">
                    Accept & Enter the Realm
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnAccepted { get; set; }

    private async Task AcceptTerms()
    {
        await OnAccepted.InvokeAsync();
    }
}
